{
  "name": "pyatkov-index",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "fetch-data": "tsx pipeline/fetch.ts",
    "pipeline": "tsx pipeline/build.ts",
    "serve": "cd site && yarn serve",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck-all": "tsc --noEmit && cd site && yarn typecheck",
    "check-data-drift": "tsx pipeline/check-data-drift.ts",
    "verify": "yarn typecheck-all && yarn test && yarn pipeline && yarn check-data-drift"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
