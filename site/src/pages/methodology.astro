---
import Base from '../layouts/Base.astro';
import rankings from '../data/rankings.json';
import weightsData from '../data/weights.json';
import { displayName, formatBuiltDate } from '../lib/format.ts';
import { impliedZ } from '../lib/weigh.ts';
import { absUrl, pageId, ID } from '../lib/seo.ts';

// B9: honest build date + per-signal vintages emitted by the pipeline.
// Coded defensively so the page still renders against pre-regen data.
type Vintages = {
  matrix?: { source: string; note: string };
  gdp?: { series: string; label: string; selection: string; years: string; modalYear: number };
  arrivals?: { series: string; label: string; window: string; preferredYear: number; yearsUsed: string };
  migrants?: { series: string; label: string; selection: string; years: string; modalYear: number };
  population?: { series: string; label: string; selection: string; years: string; modalYear: number };
  hdi?: { source: string; year: number };
};
const meta = rankings as typeof rankings & { builtAt?: string; vintages?: Vintages };
const builtAt = meta.builtAt ?? (meta as { generatedAt?: string }).generatedAt ?? '';
const v = meta.vintages ?? {};
// Year-range strings from the pipeline use an en-dash; ranges render with a hyphen.
const range = (s: string) => s.replace(/[–—]/g, '-');

// The four signals, in the order the figure and the ledger both read them.
// Every word about a signal lives here once, so the drawing and the prose can
// never disagree about what it is or how it is scaled.
const SIGNALS = [
  {
    key: 'gdp' as const,
    label: 'GDP',
    title: 'GDP',
    source: 'World Bank, current US$',
    series: null,
    blurb: 'Economic mass, logged before z-scoring so the largest economies do not drown out everything else.',
  },
  {
    key: 'arrivals' as const,
    label: 'Arrivals',
    title: 'Tourism arrivals',
    source: 'World Bank / UN Tourism',
    series: 'ST.INT.ARVL',
    blurb: 'How much the world actually travels there, logged. A proxy, not a pure tourist count: it counts non-resident arrivals, and countries define them differently.',
  },
  {
    key: 'hdi' as const,
    label: 'HDI',
    title: 'HDI',
    source: 'UNDP Human Development Report',
    series: null,
    blurb: 'Development level, on its natural scale: the index is already bounded, so it is never logged.',
  },
  {
    key: 'migrants' as const,
    label: 'Migrants',
    title: 'Migrant stock',
    source: 'World Bank',
    series: 'SM.POP.TOTL',
    blurb: 'International migrant stock, logged: how much of the world has chosen to move there.',
  },
];

// The worked example: the formula run end to end on two real destinations.
// They are picked by SIGN, not by rank — the heaviest whose four signals all
// sit above the world average, the lightest whose four all sit below it — so
// the diverging figure can put one on each side of the axis and never have two
// bars land on the same half. The fallbacks are the plain extremes.
const wdests = weightsData.destinations;
const zsOf = (d: (typeof wdests)[number]) => SIGNALS.map((s) => d.normalized[s.key]);
const complete = (d: (typeof wdests)[number]) => d.signalsUsed === 4 && zsOf(d).every((z) => z !== null);
const high = wdests.find((d) => complete(d) && zsOf(d).every((z) => (z ?? 0) > 0)) ?? wdests[0];
const low =
  [...wdests].reverse().find((d) => complete(d) && zsOf(d).every((z) => (z ?? 0) < 0)) ??
  wdests[wdests.length - 1];
// The composite read back out of the weight itself — ln(w)/1.25 — so the
// figure's Z row can never drift from the weight row underneath it.
const highZ = impliedZ(high.weight);
const lowZ = impliedZ(low.weight);

// One σ axis, shared by the worked example and the ledger's range strips: the
// widest bar either of them draws, rounded up to the next half sigma so the
// longest bar stops short of the margin.
const spreads = SIGNALS.map((s) => {
  const vals = wdests.map((d) => d.normalized[s.key]).filter((v): v is number => v !== null);
  return { min: Math.min(...vals), max: Math.max(...vals) };
});
const axis =
  Math.ceil(
    Math.max(
      ...spreads.flatMap((r) => [Math.abs(r.min), Math.abs(r.max)]),
      ...[...zsOf(high), ...zsOf(low)].map((z) => Math.abs(z ?? 0)),
      Math.abs(highZ),
      Math.abs(lowZ),
    ) * 2,
  ) / 2;
const barWidth = (z: number | null) => `${((Math.abs(z ?? 0) / axis) * 100).toFixed(1)}%`;
// The same signed reading the destinations ledger uses for its z-score cells.
const zText = (z: number | null) => (z === null ? '—' : (z >= 0 ? '+' : '') + z.toFixed(2));
const highName = displayName(high.iso3, high.name);
const lowName = displayName(low.iso3, low.name);
const ratio = Math.round(high.weight / low.weight);
const sigmaGap = (highZ - lowZ).toFixed(1);

const base = import.meta.env.BASE_URL;
// The four derived datasets are copied to public/data/ at build time; these are
// both the Dataset's distribution URLs and the visible download links below.
const downloads = [
  { file: 'rankings.json', label: 'Passport rankings', desc: 'Every passport with its score, rank, count rank, and access counts.' },
  { file: 'weights.json', label: 'Destination weights', desc: 'Every destination with its weight and the four z-scored signals behind it.' },
  { file: 'openness.json', label: 'Destination openness', desc: 'Every destination with its openness score and rank.' },
  { file: 'matrix.json', label: 'Visa matrix', desc: 'The full passport-by-destination access matrix the index is computed from.' },
];

// Coverage is the span the signals actually observe, read off the vintages the
// pipeline emits rather than restated by hand where it could drift.
const coverageYears = [v.gdp?.years, v.arrivals?.window]
  .filter((s): s is string => Boolean(s))
  .flatMap((s) => s.match(/\d{4}/g) ?? [])
  .map(Number);
const temporalCoverage = coverageYears.length
  ? `${Math.min(...coverageYears)}/${Math.max(...coverageYears)}`
  : undefined;

const canonical = absUrl(Astro.url.pathname);
const dataset = {
  '@type': 'Dataset',
  '@id': ID.dataset,
  name: 'The Pyatkov Index: weighted passport and destination-openness rankings',
  description:
    `A weighted passport index over ${rankings.totalDestinations} destinations. Each destination's weight is exp(1.25 × Z), where Z is the mean of its available z-scores on log-scaled GDP, log-scaled tourism arrivals, HDI, and log-scaled migrant stock. Each passport scores 0-100 as the credit-weighted share of the world's destination weight it can reach, with full credit for visa-free and visa-on-arrival access, a fifth for an eVisa, and none for a visa requirement. The same credits run backwards to rate every destination's openness by the share of the world's foreign population it admits.`,
  url: canonical,
  license: 'https://creativecommons.org/licenses/by/4.0/',
  creator: { '@id': ID.creator },
  isAccessibleForFree: true,
  inLanguage: 'en',
  // Build date only. The page says below that this is not the vintage of any
  // single signal, so there is deliberately no datePublished to imply one.
  ...(builtAt ? { dateModified: builtAt } : {}),
  keywords: [
    'passport index',
    'visa-free travel',
    'weighted ranking',
    'destination openness',
    'travel freedom',
    'z-score',
  ],
  spatialCoverage: { '@type': 'Place', name: 'World' },
  ...(temporalCoverage ? { temporalCoverage } : {}),
  measurementTechnique:
    'Composite z-score: each signal is z-scored across the destinations that report it (GDP, arrivals, and migrant stock log-scaled first; HDI on its natural scale), averaged over the available signals, then exponentiated as exp(1.25 × Z) to give the destination weight.',
  variableMeasured: [
    { '@type': 'PropertyValue', name: 'Pyatkov score', description: "Share of the world's destination weight a passport can reach.", minValue: 0, maxValue: 100 },
    { '@type': 'PropertyValue', name: 'Count rank', description: 'Rank from the same tier credits with every destination weighted equally at 1.' },
    { '@type': 'PropertyValue', name: 'Delta from weighting', description: 'Count rank minus weighted rank: how far weighting moves a passport.' },
    { '@type': 'PropertyValue', name: 'Destination weight', description: 'exp(1.25 × Z) for a destination, in raw signal units, not a percentage.' },
    { '@type': 'PropertyValue', name: 'Openness', description: "Credit-weighted share of the world's foreign population a destination admits, an eVisa counting a fifth.", minValue: 0, maxValue: 100 },
  ],
  citation: [
    { '@type': 'CreativeWork', name: 'imorte/passport-index-data', url: 'https://github.com/imorte/passport-index-data' },
    { '@type': 'CreativeWork', name: 'World Bank World Development Indicators', url: 'https://data.worldbank.org/' },
    { '@type': 'CreativeWork', name: 'UNDP Human Development Report', url: 'https://hdr.undp.org/' },
  ],
  distribution: downloads.map((d) => ({
    '@type': 'DataDownload',
    name: d.label,
    encodingFormat: 'application/json',
    contentUrl: absUrl(`${base}data/${d.file}`),
  })),
};

const article = {
  '@type': 'TechArticle',
  '@id': pageId(Astro.url.pathname, 'article'),
  headline: 'Methodology of the Pyatkov Index',
  about: { '@id': ID.dataset },
  author: { '@id': ID.creator },
  ...(builtAt ? { dateModified: builtAt } : {}),
  inLanguage: 'en',
  isPartOf: { '@id': ID.website },
  proficiencyLevel: 'Expert',
};
---
<Base
  title="Methodology - Pyatkov Index"
  description="The formula, data sources, and per-signal data vintages behind the Pyatkov Index."
  jsonld={[dataset, article]}
>
  <section class="method" aria-label="How a destination's weight is computed">
    <div class="hero method-lede">
      <h1>How the number is made</h1>
      <p class="tagline">
        Other indexes count destinations: visa-free access to a micronation is worth exactly as much as
        visa-free access to the United States. This one weighs them — four public signals per destination,
        averaged as standard deviations from the world average, then raised to a power.
      </p>
      <p class="fx">
        <span class="fx-lit">weight =</span>
        <span class="fx-lit">exp(</span>
        <span class="fx-part"><b>1.25</b><small>chosen</small></span>
        <span class="fx-lit">×</span>
        <span class="fx-part"><b>Z</b><small>measured</small></span>
        <span class="fx-lit">)</span>
      </p>
      <p class="method-note">
        One of those numbers is a decision and the other is data. Everything below is that line, worked out:
        the four signals, the credit each kind of access earns, and the score they add up to.
      </p>
    </div>

    <figure class="wx">
      <figcaption class="wx-row wx-key">
        <span class="wx-name" aria-hidden="true"></span>
        <span class="wx-z" aria-hidden="true"></span>
        <span class="wx-track">
          <span class="wx-half wx-neg"><b>{lowName}</b><br />the lightest</span>
          <span class="wx-half wx-pos"><b>{highName}</b><br />the heaviest</span>
        </span>
        <span class="wx-z" aria-hidden="true"></span>
      </figcaption>
      <div class="wx-rows">
        {SIGNALS.map((s, i) => (
          <div class="wx-row" style={`--i:${i}`}>
            <span class="wx-name">{s.label}</span>
            <span class="wx-z">{zText(low.normalized[s.key])}</span>
            <span class="wx-track">
              <span class="wx-half wx-neg"><i class="wx-bar wx-low" style={`--w:${barWidth(low.normalized[s.key])}`} /></span>
              <span class="wx-half wx-pos"><i class="wx-bar wx-high" style={`--w:${barWidth(high.normalized[s.key])}`} /></span>
            </span>
            <span class="wx-z">{zText(high.normalized[s.key])}</span>
          </div>
        ))}
        <div class="wx-row wx-sum" style={`--i:4`}>
          <span class="wx-name">mean Z</span>
          <span class="wx-z">{zText(lowZ)}</span>
          <span class="wx-track">
            <span class="wx-half wx-neg"><i class="wx-bar wx-low" style={`--w:${barWidth(lowZ)}`} /></span>
            <span class="wx-half wx-pos"><i class="wx-bar wx-high" style={`--w:${barWidth(highZ)}`} /></span>
          </span>
          <span class="wx-z">{zText(highZ)}</span>
        </div>
        <div class="wx-row wx-foot">
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span class="wx-track"><span class="wx-axis-label">the world average</span></span>
          <span aria-hidden="true"></span>
        </div>
      </div>
      <div class="wx-out">
        <div class="wx-row wx-lane" style={`--i:5`}>
          <span class="wx-name">weight</span>
          <span aria-hidden="true"></span>
          <span class="wx-track"><i class="wx-bar wx-high" style="--w:100%" /></span>
          <span class="wx-z">{high.weight.toFixed(2)}</span>
        </div>
        <div class="wx-row wx-lane" style={`--i:6`}>
          <span aria-hidden="true"></span>
          <span aria-hidden="true"></span>
          <span class="wx-track"><i class="wx-bar wx-low" style={`--w:${((low.weight / high.weight) * 100).toFixed(2)}%`} /></span>
          <span class="wx-z">{low.weight.toFixed(2)}</span>
        </div>
        <p class="wx-punch">
          <b>{ratio}×</b> the weight, out of {sigmaGap} standard deviations — the exponent is what lets
          quality beat count.
        </p>
      </div>
    </figure>
  </section>

  <h2>Destination weights</h2>
  <p>Each of the {rankings.totalDestinations} destinations gets a weight from four signals, and nothing else:</p>
  <div class="sig-ledger">
    <div class="sig-head" aria-hidden="true">
      <span>Signal</span>
      <span>What it measures</span>
      <span>Where the world falls, in σ</span>
    </div>
    <ul class="sig-rows">
      {SIGNALS.map((s, i) => (
        <li class="sig">
          <div class="sig-id">
            <h3>{s.title}</h3>
            <span class="sig-src">{s.source}{s.series && <Fragment>, series <code>{s.series}</code></Fragment>}</span>
          </div>
          <p class="sig-blurb">{s.blurb}</p>
          <div
            class="sig-spread"
            role="img"
            aria-label={`On ${s.title} the ${wdests.length} destinations run from ${zText(spreads[i].min)} to ${zText(spreads[i].max)} standard deviations around the world average.`}
          >
            <span class="wx-track">
              <span class="wx-half wx-neg"><i class="wx-bar wx-low" style={`--w:${barWidth(spreads[i].min)}`} /></span>
              <span class="wx-half wx-pos"><i class="wx-bar wx-high" style={`--w:${barWidth(spreads[i].max)}`} /></span>
            </span>
            <span class="sig-range">{zText(spreads[i].min)} to {zText(spreads[i].max)}</span>
          </div>
        </li>
      ))}
    </ul>
  </div>
  <p>
    Every signal is put on one common scale, a population <em>z-score</em> (how many standard deviations
    above or below the destination average it sits), computed only over the destinations that actually
    report that signal. GDP, arrivals, and migrant stock are logged first because they span several orders
    of magnitude; HDI is already a bounded index and is z-scored on its natural scale. A destination's
    composite <code>Z</code> is the mean of whichever z-scores it has (a missing signal is simply left out
    of the mean, never imputed off-scale).
  </p>
  <p>
    The weight is then a tempered exponential of that composite: <code>weight = exp(1.25 × Z)</code>. The
    exponential is what lets destination <em>quality</em> genuinely dominate <em>count</em>. One composite
    standard deviation of extra value is worth about <code>exp(1.25) ≈ 3.5×</code> more weight, so a handful
    of strong destinations (Germany, Japan, the United States) outweigh dozens of weak ones, while the score
    stays smooth, strictly monotonic in value, and bounded.
  </p>

  <h2>Access credit</h2>
  <ul class="credit-list">
    <li><span class="tier-key tier-visa-free">Visa-free / freedom of movement</span> <span class="credit">1.0</span></li>
    <li><span class="tier-key tier-visa-on-arrival">Visa on arrival / eTA</span> <span class="credit">1.0</span></li>
    <li><span class="tier-key tier-e-visa">eVisa</span> <span class="credit">0.2</span></li>
    <li><span class="tier-key tier-visa-required">Visa required / no admission</span> <span class="credit">0</span></li>
  </ul>
  <p>
    The test starts binary: is entry decided <em>at the border</em>, or does it require permission <em>before
    departure</em>? Visa on arrival and eTA need nothing to board a plane, so they count as fully open. A visa
    arranged in advance at a consulate earns nothing. An eVisa sits between the two — it must still clear
    before you fly, so it is not freedom of movement, but it is an online form that is granted far more
    readily than a consular visa, so it earns a fifth of full credit rather than nothing.
  </p>

  <h2>The score</h2>
  <div class="formula-card">
    <code>score = 100 × Σ credit(passport, d) × weight(d) / Σ weight(d)</code>
    <span class="note">The share of the world's destination value this passport can reach.</span>
  </div>
  <p>
    <strong>Both</strong> sums run over every destination <em>including the passport's own country</em>, which every passport
    admits visa-free (credit 1.0). A country's own destination value therefore accrues to its own score, so
    large, high-value home economies (the United States most of all, since it is the single most valuable
    destination) rank higher than they would if their own weight were thrown away. Because numerator and
    denominator cover the same full pool, a passport with full visa-free access still scores exactly 100, and
    the score reads as "percent of the world's destination value this passport can reach". The <strong id="count-rank">Count
    rank</strong>, shown on each passport's own page, is the ranking you get from the same access credits over
    the same full set of destinations but with every destination worth 1, a plain "how many places can you go"
    count. The <strong id="delta">Δ from weighting</strong> beside it is the gap between the two, so a passport that
    reaches disproportionately valuable destinations rises and one skewed toward low-value destinations falls.
  </p>

  <h2>The openness rating</h2>
  <p>
    The index also runs backwards. Where a passport score asks how much of the world's destination
    <em>value</em> a passport opens, an <a href={`${import.meta.env.BASE_URL}openness/`}>openness score</a>
    asks how much of the world's <em>people</em> a destination lets in from outside:
  </p>
  <p><code>openness(d) = 100 × Σ<sub>p ≠ d</sub> credit(p, d) × population(p) / Σ<sub>p ≠ d</sub> population(p)</code></p>
  <p>
    Both sums run over the {rankings.totalDestinations - 1} <em>foreign</em> passports, excluding the
    destination's own. This is the one place the openness rating deliberately departs from the passport
    score, which counts a country's own destination value toward itself. Every country admits its own
    citizens, so including them would measure nothing except population size — handing large countries free
    points for a policy they all share. Because numerator and denominator cover the same foreign pool, a
    destination open to every foreign passport scores exactly 100 and one that admits none scores exactly 0.
    The number reads as a percentage: the credit-weighted share of the world's people outside its borders it
    admits, on the same graded credit ladder the passport score uses — border access in full, an eVisa a fifth.
  </p>
  <p>
    Population comes from the World Bank series <code>SP.POP.TOTL</code>, latest available per country. It is
    used only as this denominator: it is not one of the four destination-weight signals above, and adding it
    moved no passport score. Each destination's page carries a <strong>&Delta; from weighting</strong>, the
    mirror of the &Delta; on the rankings table — how far that destination moves once the passports it
    admits are weighted by the people behind them instead of counted one apiece.
  </p>

  <h2>Sources &amp; data vintages</h2>
  <p>
    Visa matrix: the open <a href="https://github.com/imorte/passport-index-data">passport-index-data</a> dataset
    (the maintained successor to the archived <code>ilyankou/passport-index-dataset</code>, PassportIndex.org
    data). Economic and social signals: the World Bank API and UNDP Human Development Report downloads.
    A few passport-issuing entities absent from those sources (Taiwan, Vatican City, and North Korea in part)
    use hand-researched values documented in the repository. The {rankings.totalDestinations} destinations are
    sovereign states and SARs; dependent territories with their own visa regimes are out of scope, inherited
    from the upstream dataset.
  </p>
  {meta.vintages && (
    <Fragment>
      <p>
        Because the signals carry different observation years, we disclose each one's vintage rather than
        a single snapshot label:
      </p>
      <ul class="vintages">
        {v.matrix && <li><strong>Visa matrix</strong>: {v.matrix.source} ({v.matrix.note})</li>}
        {v.gdp && <li><strong>{v.gdp.label}</strong> (<code>{v.gdp.series}</code>): {v.gdp.selection}, years {range(v.gdp.years)} (modal {v.gdp.modalYear})</li>}
        {v.arrivals && <li><strong>{v.arrivals.label}</strong> (<code>{v.arrivals.series}</code>): {range(v.arrivals.window)} window, preferring {v.arrivals.preferredYear}; years used {range(v.arrivals.yearsUsed)}</li>}
        {v.migrants && <li><strong>{v.migrants.label}</strong> (<code>{v.migrants.series}</code>): {v.migrants.selection}, years {range(v.migrants.years)} (modal {v.migrants.modalYear})</li>}
        {v.population && <li><strong>{v.population.label}</strong> (<code>{v.population.series}</code>): {v.population.selection}, years {range(v.population.years)} (modal {v.population.modalYear}) — the openness denominator, not a weight signal</li>}
        {v.hdi && <li><strong>HDI</strong>: {v.hdi.source}, reference year {v.hdi.year}</li>}
      </ul>
    </Fragment>
  )}
  <p>
    Built {formatBuiltDate(builtAt)}, the date the pipeline last ran, not the vintage of any single signal. All raw data and
    code are in the repo; the entire index is reproducible with one command.
  </p>

  <h2 id="download">Download the data</h2>
  <p>
    The four derived datasets are published alongside the site as plain JSON, under
    <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a>. They are the same files the
    pages above are rendered from, rebuilt every time the pipeline runs.
  </p>
  <ul class="downloads">
    {downloads.map((d) => (
      <li>
        <a href={`${base}data/${d.file}`} download><code>{d.file}</code> — {d.label}</a>
        <span>{d.desc}</span>
      </li>
    ))}
  </ul>

  <style>
    .downloads { list-style: none; margin: 0 0 8px; padding: 0; max-width: 65ch; }
    .downloads li {
      padding: 8px 0;
      border-bottom: 1px solid var(--border-hairline);
    }
    .downloads span {
      display: block;
      margin-top: 2px;
      font-size: var(--text-caption);
      line-height: var(--leading-caption);
      letter-spacing: var(--tracking-caption);
      color: var(--color-slate);
    }
  </style>
</Base>
