---
import Base from '../layouts/Base.astro';
import Rosette from '../components/Rosette.astro';
import rankings from '../data/rankings.json';
import { deltaLabel, displayName, flagEmoji, fmt, searchIndex } from '../lib/format.ts';
const base = import.meta.env.BASE_URL;
// B9: the pipeline now emits an honest build date (builtAt) plus per-signal
// vintages. Fall back to the legacy generatedAt field for pre-regen data.
const meta = rankings as typeof rankings & { builtAt?: string; vintages?: unknown };
const builtAt = meta.builtAt ?? (meta as { generatedAt?: string }).generatedAt ?? '';
---
<Base title="Pyatkov Index — weighted passport ranking" description="A passport index where strong destinations count more than weak ones.">
  <div class="doc-hero">
    <Rosette />
    <p class="kicker">An index of passport value</p>
    <h1>The Pyatkov Index</h1>
    <p class="lede">
      Every passport, scored 0–100 by the share of the reachable world's destination <em>value</em> it can
      reach — across {rankings.totalDestinations} sovereign-state and SAR destinations (dependent territories are
      out of scope, inherited from the upstream dataset). Destinations are weighted by GDP, arrivals, HDI, and
      migrant stock — the Δ column shows how far each passport moves compared with counting every country equally.
    </p>
  </div>
  <div class="specline">
    <span><strong>{rankings.passports.length}</strong> passports</span>
    <span><strong>{rankings.totalDestinations}</strong> destinations</span>
    <span>Signals <strong>GDP · Arrivals · HDI · Migrants</strong></span>
    <span>Built <strong>{builtAt}</strong></span>
    <span><a href={`${base}methodology/`}>Data vintages</a></span>
  </div>
  <input type="search" id="filter" placeholder="Filter countries…" aria-label="Filter countries" />
  <div class="table-scroll">
  <table id="rankings">
    <thead>
      <tr>
        <th scope="col" data-sort="rank" aria-sort="ascending" tabindex="0">#</th>
        <th scope="col" data-sort="name" tabindex="0">Passport</th>
        <th scope="col" data-sort="score" tabindex="0">Score</th>
        <th scope="col" data-sort="delta" tabindex="0">Δ vs count</th>
        <th scope="col" data-sort="equalRank" tabindex="0">Count rank</th>
      </tr>
    </thead>
    <tbody>
      {rankings.passports.map((p) => (
        <tr data-name={displayName(p.iso3, p.name).toLowerCase()} data-search={searchIndex(p)} data-rank={p.rank} data-score={p.score} data-delta={p.delta} data-equalrank={p.equalRank}>
          <td>{p.rank}</td>
          <td><a href={`${base}passport/${p.iso3.toLowerCase()}/`}>{flagEmoji(p.iso2)} {displayName(p.iso3, p.name)}</a></td>
          <td class="score-cell" style={`--w:${p.score}%`}>{fmt(p.score)}<span class="bar" aria-hidden="true"></span></td>
          <td class={p.delta > 0 ? 'up' : p.delta < 0 ? 'down' : ''}>{deltaLabel(p.delta)}</td>
          <td>{p.equalRank}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>

  <script>
    const input = document.getElementById('filter') as HTMLInputElement;
    const tbody = document.querySelector('#rankings tbody')!;
    const rows = [...tbody.querySelectorAll('tr')];

    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      // B8: match the full search blob (display name + iso3/iso2 + aliases),
      // so "Palestine", "Turkey", "South Korea", "kor", etc. all resolve.
      for (const r of rows) (r as HTMLElement).hidden = !r.dataset.search!.includes(q);
    });

    const DEFAULT_ASC: Record<string, boolean> = {
      rank: true,
      equalrank: true,
      name: true,
      score: false,
      delta: false,
    };

    const headers = [...document.querySelectorAll('th[data-sort]')] as HTMLElement[];
    let sortKey = 'rank';
    let asc = true;

    headers.forEach((th) => {
      th.addEventListener('click', () => {
        const key = th.dataset.sort!;
        const lowerKey = key.toLowerCase();
        asc = key === sortKey ? !asc : DEFAULT_ASC[lowerKey];
        sortKey = key;
        const val = (r: Element) =>
          key === 'name' ? r.getAttribute('data-name')! : parseFloat(r.getAttribute(`data-${lowerKey}`)!);
        rows
          .sort((a, b) => {
            const [x, y] = [val(a), val(b)];
            return (x < y ? -1 : x > y ? 1 : 0) * (asc ? 1 : -1);
          })
          .forEach((r) => tbody.appendChild(r));

        headers.forEach((h) => h.removeAttribute('aria-sort'));
        th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');
      });
    });

    // Keyboard operability: Enter/Space on a focused header triggers the same
    // click handler above. Additive only — does not touch the sort logic.
    headers.forEach((th) => {
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          th.click();
        }
      });
    });
  </script>
</Base>
