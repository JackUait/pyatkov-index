---
import Base from '../layouts/Base.astro';
import rankings from '../data/rankings.json';
import { deltaLabel, displayName, flagEmoji, fmt, formatBuiltDate, searchIndex } from '../lib/format.ts';
const base = import.meta.env.BASE_URL;
// B9: the pipeline now emits an honest build date (builtAt) plus per-signal
// vintages. Fall back to the legacy generatedAt field for pre-regen data.
const meta = rankings as typeof rankings & { builtAt?: string; vintages?: unknown };
const builtAt = meta.builtAt ?? (meta as { generatedAt?: string }).generatedAt ?? '';
---
<Base title="Pyatkov Index: the weighted passport ranking" description="A passport index where strong destinations count more than weak ones.">
  <section class="hero">
    <div class="mark-row" aria-hidden="true">
      {rankings.passports.slice(0, 7).map((p, i) => (
        <span class="mark" style={`--i:${i}`}>{flagEmoji(p.iso2)}</span>
      ))}
    </div>
    <h1>
      Not all destinations<br />are <span class="pill-word">equal</span><svg class="sparkle" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c.9 6.5 5.5 11.1 12 12-6.5.9-11.1 5.5-12 12-.9-6.5-5.5-11.1-12-12C6.5 11.1 11.1 6.5 12 0z" /></svg>
    </h1>
    <p class="tagline">A passport index that weights every destination by what access to it is actually worth.</p>
    <div class="actions">
      <a class="btn btn-lg btn-primary" href="#rankings-card">See the rankings</a>
      <a class="btn btn-lg btn-ghost" href={`${base}methodology/`}>Methodology</a>
    </div>
  </section>

  <section class="statline" aria-label="Index coverage">
    <div><strong>{rankings.passports.length}</strong><span>passports ranked</span></div>
    <div><strong>{rankings.totalDestinations}</strong><span>destinations weighted</span></div>
    <div><strong>4</strong><span>weighting signals</span></div>
    <div><strong>{formatBuiltDate(builtAt)}</strong><span>last built</span></div>
  </section>

  <p class="table-intro">
    Every passport is scored 0 to 100 by the share of the world's destination value it can reach.
    Destinations are weighted by GDP, tourism arrivals, HDI, and migrant stock, and the Δ column
    shows how far weighting moves each passport versus counting every destination equally.
  </p>
  <div class="card card-mockup" id="rankings-card">
  <div class="card-header">
    <h2>The ranking</h2>
    <span class="count">{rankings.passports.length} passports</span>
    <input type="search" id="filter" placeholder="Filter countries" aria-label="Filter countries" />
  </div>
  <div class="table-scroll">
  <table id="rankings">
    <thead>
      <tr>
        <th scope="col" data-sort="rank" aria-sort="ascending" tabindex="0">#</th>
        <th scope="col" data-sort="name" tabindex="0">Passport</th>
        <th scope="col" data-sort="score" tabindex="0">Score</th>
        <th scope="col" data-sort="delta" tabindex="0">Δ vs count</th>
        <th scope="col" data-sort="equalRank" tabindex="0">Count rank</th>
      </tr>
    </thead>
    <tbody>
      {rankings.passports.map((p) => (
        <tr data-name={displayName(p.iso3, p.name).toLowerCase()} data-search={searchIndex(p)} data-rank={p.rank} data-score={p.score} data-delta={p.delta} data-equalrank={p.equalRank}>
          <td>{p.rank}</td>
          <td><a href={`${base}passport/${p.iso3.toLowerCase()}/`}>{flagEmoji(p.iso2)} {displayName(p.iso3, p.name)}</a></td>
          <td class="score-cell" style={`--w:${p.score}%`}>{fmt(p.score)}<span class="bar" aria-hidden="true"></span></td>
          <td class={p.delta > 0 ? 'up' : p.delta < 0 ? 'down' : ''}>{deltaLabel(p.delta)}</td>
          <td>{p.equalRank}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>
  <p id="no-results" hidden>No passports match your filter. Try a country name like Portugal, or a code like PRT.</p>
  </div>

  <script>
    const input = document.getElementById('filter') as HTMLInputElement;
    const tbody = document.querySelector('#rankings tbody')!;
    const rows = [...tbody.querySelectorAll('tr')];

    const noResults = document.getElementById('no-results')!;
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      // B8: match the full search blob (display name + iso3/iso2 + aliases),
      // so "Palestine", "Turkey", "South Korea", "kor", etc. all resolve.
      let visible = 0;
      for (const r of rows) {
        const hide = !r.dataset.search!.includes(q);
        (r as HTMLElement).hidden = hide;
        if (!hide) visible++;
      }
      noResults.hidden = visible > 0;
    });

    const DEFAULT_ASC: Record<string, boolean> = {
      rank: true,
      equalrank: true,
      name: true,
      score: false,
      delta: false,
    };

    const headers = [...document.querySelectorAll('th[data-sort]')] as HTMLElement[];
    let sortKey = 'rank';
    let asc = true;

    headers.forEach((th) => {
      th.addEventListener('click', () => {
        const key = th.dataset.sort!;
        const lowerKey = key.toLowerCase();
        asc = key === sortKey ? !asc : DEFAULT_ASC[lowerKey];
        sortKey = key;
        const val = (r: Element) =>
          key === 'name' ? r.getAttribute('data-name')! : parseFloat(r.getAttribute(`data-${lowerKey}`)!);
        rows
          .sort((a, b) => {
            const [x, y] = [val(a), val(b)];
            return (x < y ? -1 : x > y ? 1 : 0) * (asc ? 1 : -1);
          })
          .forEach((r) => tbody.appendChild(r));

        headers.forEach((h) => h.removeAttribute('aria-sort'));
        th.setAttribute('aria-sort', asc ? 'ascending' : 'descending');
      });
    });

    // Keyboard operability: Enter/Space on a focused header triggers the same
    // click handler above. Additive only — does not touch the sort logic.
    headers.forEach((th) => {
      th.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          th.click();
        }
      });
    });
  </script>
</Base>
