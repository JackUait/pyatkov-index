---
import Base from '../../layouts/Base.astro';
import openness from '../../data/openness.json';
import rankings from '../../data/rankings.json';
import weightsData from '../../data/weights.json';
import matrix from '../../data/matrix.json';
import { displayName, fmt, reconcilePoints, searchIndex, verbFor, withArticle } from '../../lib/format.ts';
import { CREDIT, LABEL, TIERS, type Tier } from '../../lib/credit.ts';
import { ID, pageId } from '../../lib/seo.ts';
import { countryNode } from '../../lib/schema.ts';
import Flag from '../../components/Flag.astro';

export function getStaticPaths() {
  return openness.destinations.map((d) => ({ params: { iso3: d.iso3.toLowerCase() }, props: { dest: d } }));
}

const { dest: d } = Astro.props;
const base = import.meta.env.BASE_URL;

const access = matrix as Record<string, Record<string, string>>;
// Ladder position, not credit: the credit ladder collapses visa-free and on-arrival onto
// one value, so it cannot order the four tiers for display. Higher = stronger access, which
// keeps the table's default sort descending and its rows grouped by tier.
const ladder = (cat: Tier) => TIERS.length - TIERS.indexOf(cat);

// Every FOREIGN passport, with the access it gets to THIS destination. The
// destination's own passport is excluded, matching the score: every country
// admits its own citizens, so counting them measures nothing.
const holders = rankings.passports
  .filter((p) => p.iso3 !== d.iso3)
  .map((p) => ({ ...p, category: access[p.iso3][d.iso3] as Tier }));
// Default order: strongest access first, then by the passport's own index score —
// so the table reads as a rating of passports for getting into this destination.
const ordered = [...holders].sort(
  (a, b) => ladder(b.category) - ladder(a.category) || b.score - a.score || a.name.localeCompare(b.name),
);

// Tier rows, with points reconciled so they sum exactly to the displayed score.
const reconciled = reconcilePoints(TIERS.map((t) => d.points[t as keyof typeof d.points]), d.score);
const tierRows = TIERS.map((t, i) => ({
  cat: t,
  points: reconciled[i],
  count: d.counts[t as keyof typeof d.counts],
}));

// This destination's own weight in the passport index, and where that ranks.
const weightIdx = weightsData.destinations.findIndex((w) => w.iso3 === d.iso3);
const weight = weightsData.destinations[weightIdx];
const ordinal = (n: number) => {
  const rem100 = n % 100;
  if (rem100 >= 11 && rem100 <= 13) return `${n}th`;
  return `${n}${['th', 'st', 'nd', 'rd'][n % 10] ?? 'th'}`;
};
const places = (n: number) => `${n} ${n === 1 ? 'place' : 'places'}`;
// Its own passport's row, for the cross-link.
const ownPassport = rankings.passports.find((p) => p.iso3 === d.iso3);

const name = displayName(d.iso3, d.name);
// Every use on this page is a sentence subject or the object of a preposition ("outside
// {name}", "who can enter {name}"), so the article-bearing form is the default here.
const theName = withArticle(d.iso3, d.name);
const totalDests = openness.destinations.length;

// The "wide spread of nationalities" reading of a negative delta only holds if there IS a
// spread: eighteen destinations with delta < 0 admit fewer than ten passports openly, and
// three admit none at all, where the old sentence followed "0 enter visa-free" with a
// claim that the place lets in a wide spread. A shift of one or two places is likewise
// inside the noise of a densely tied count rank and gets no causal story.
const openHolders = d.counts['visa-free'] + d.counts['visa-on-arrival'];
const NEAR_TIE = 2;
const FEW_OPEN = 10;
const deltaWords =
  openHolders === 0
    ? `No foreign passport enters ${theName} without prior permission, so weighting the passports by the populations behind them has nothing left to reorder: the headcount rank of #${d.equalRank} and the weighted #${d.rank} are both simply the floor of the table.`
    : d.delta === 0
      ? `Counting passports and weighting them by the populations behind them both put ${theName} at #${d.equalRank}, so its openness is not an artefact of which particular nationalities it lets in.`
      : Math.abs(d.delta) <= NEAR_TIE
        ? `Weighting each passport by the population behind it moves ${theName} ${places(Math.abs(d.delta))} ${d.delta > 0 ? 'above' : 'below'} its plain headcount rank of #${d.equalRank} — close enough that the two orderings agree about it.`
        : d.delta > 0
          ? `Weighting each passport by the population behind it lifts ${theName} ${places(d.delta)} above its plain headcount rank of #${d.equalRank}: the nationalities it admits are unusually populous ones.`
          : openHolders < FEW_OPEN
            ? `Weighting each passport by the population behind it costs ${theName} ${places(-d.delta)} against its plain headcount rank of #${d.equalRank}: the few nationalities it does admit are comparatively small ones.`
            : `Weighting each passport by the population behind it costs ${theName} ${places(-d.delta)} against its plain headcount rank of #${d.equalRank}: it admits a wide spread of nationalities, but comparatively small ones.`;

// "Still needs permission before departure" spans both the eVisa and visa-required tiers:
// an eVisa must clear before you fly just as a consular visa must. Filtering on
// 'visa-required' alone named a weaker passport than the strongest such one on 29 pages
// (Myanmar named Liechtenstein #12 while Spain #4 needs an eVisa). Sorted by the passport's
// own score, not by tier, so "strongest" spans both apply-ahead tiers.
const strongestClosed = holders
  .filter((p) => CREDIT[p.category] < 1)
  .sort((a, b) => b.score - a.score || a.name.localeCompare(b.name))[0];

// Assembled here, not inline: the template drops the whitespace between an expression
// and the text on the next line, and this sentence wraps. Only what no tile or table on
// the page already shows earns a sentence: the score, rank, and tier counts live in the
// stats and the tier table, so the prose carries just the weighting insight, the
// strongest apply-ahead passport, and this cross-reference into the passport index.
const weightLine =
  `As a destination in the passport index, ${theName} carries a weight of ${weight.weight.toFixed(3)}, ` +
  `${weightIdx === 0 ? 'the highest of them all' : `the ${ordinal(weightIdx + 1)} highest of ${weightsData.destinations.length}`}.`;

const countryId = pageId(Astro.url.pathname, 'country');
const country = countryNode({
  id: countryId,
  name,
  iso3: d.iso3,
  iso2: d.iso2,
  // Qualified with "openness" for the same reason the passport page qualifies with
  // "passport": both pages describe the same country, and an unqualified "Count rank" on
  // each would merge into one property holding two contradictory values.
  measures: [
    { propertyID: 'openness-score', name: 'Openness', value: Number(fmt(d.score)), minValue: 0, maxValue: 100 },
    { propertyID: 'openness-rank', name: 'Openness rank', value: d.rank },
    { propertyID: 'openness-count-rank', name: 'Openness count rank', value: d.equalRank },
    { propertyID: 'openness-delta', name: 'Openness delta from weighting', value: d.delta },
  ],
});

const MARK_COLORS = ['var(--color-signal-blue)', 'var(--color-coral)', 'var(--color-marigold)', 'var(--color-sky-wash)'];
const markColor = MARK_COLORS[d.rank % MARK_COLORS.length];
---
<Base
  title={`Who can enter ${theName} - Pyatkov Index`}
  description={`${name}: openness rank #${d.rank} of ${totalDests}, score ${fmt(d.score)}/100. Of ${holders.length} foreign passports, ${d.counts['visa-free']} ${verbFor(d.counts['visa-free'], 'enter')} visa-free and ${d.counts['visa-on-arrival']} on arrival; ${d.counts['e-visa'] + d.counts['visa-required']} must apply first.`}
  ogType="article"
  breadcrumb={[{ name: 'Openness', href: `${base}openness/` }, { name: `Who can enter ${theName}` }]}
  mainEntityId={countryId}
  basedOnId={ID.dataset}
  jsonld={country}
>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href={`${base}openness/`}>Openness</a> <span aria-hidden="true">/</span> <span aria-current="page">Who can enter {theName}</span>
  </nav>

  <section class="passport-hero">
    <span class="mark" style={`--mark-color:${markColor}`} aria-hidden="true"><Flag iso2={d.iso2} class="flag-mark" /></span>
    <h1>Who can enter {theName}</h1>
  </section>

  <dl class="stats">
    <div><dt>Openness</dt><dd>{fmt(d.score)}</dd></div>
    <div><dt>Rank</dt><dd>#{d.rank}</dd></div>
  </dl>

  <p class="lede">
    {deltaWords}
    {/* Muted when nothing enters openly: "the strongest passport that still needs
        permission" is every passport there, and deltaWords already says so. */}
    {openHolders > 0 && (strongestClosed ? (
      <Fragment> The strongest passport that still needs permission before departure is <a href={`${base}passport/${strongestClosed.iso3.toLowerCase()}/`}>{withArticle(strongestClosed.iso3, strongestClosed.name)}</a>{`, ranked #${strongestClosed.rank} with a score of ${fmt(strongestClosed.score)}.`}</Fragment>
    ) : (
      <Fragment>{` No passport needs permission before departure: ${theName} admits every one of them at the border.`}</Fragment>
    ))}
  </p>

  <p>
    {weightLine}
    {ownPassport && (
      <Fragment> Its own passport ranks <a href={`${base}passport/${d.iso3.toLowerCase()}/`}>#{ownPassport.rank}</a>.</Fragment>
    )}
  </p>

  <h2>Where the openness comes from</h2>
  <div class="card">
  <div class="table-scroll">
  <table class="tier-table">
    <caption class="sr-only">How {name}'s openness of {fmt(d.score)} splits across the four access tiers</caption>
    <thead><tr><th scope="col">Access tier</th><th scope="col">Passports</th><th scope="col">Points</th></tr></thead>
    <tbody>
      {tierRows.map((t) => (
        <tr><td><span class={`tier-key tier-${t.cat}`}>{LABEL[t.cat]}</span></td><td>{t.count}</td><td>{fmt(t.points)}</td></tr>
      ))}
    </tbody>
    <tfoot>
      <tr><th scope="row">Total (Openness)</th><td>{holders.length}</td><td>{fmt(d.score)}</td></tr>
    </tfoot>
  </table>
  </div>
  </div>

  <p class="table-intro">Its own passport is not listed: every country admits its own citizens.</p>

  <div class="card card-mockup">
  <div class="card-header">
    <h2>Every foreign passport</h2>
    <input type="search" id="filter" placeholder="Filter passports" aria-label="Filter passports" />
  </div>
  <div class="table-scroll">
  <table id="holders" class="access-table">
    <thead>
      <tr>
        <th scope="col" data-sort="credit" aria-sort="descending" tabindex="0">Access</th>
        <th scope="col" data-sort="name" tabindex="0">Passport</th>
        <th scope="col" data-sort="rank" tabindex="0">Rank</th>
        <th scope="col" data-sort="score" tabindex="0">Score</th>
      </tr>
    </thead>
    <tbody>
      {ordered.map((p) => (
        <tr data-name={displayName(p.iso3, p.name).toLowerCase()} data-search={searchIndex(p)} data-credit={ladder(p.category)} data-rank={p.rank} data-score={p.score}>
          <td><span class={`tier-key tier-${p.category}`}>{LABEL[p.category]}</span></td>
          <td><a href={`${base}passport/${p.iso3.toLowerCase()}/`}><Flag iso2={p.iso2} /> {displayName(p.iso3, p.name)}</a></td>
          <td>{p.rank}</td>
          <td>{fmt(p.score)}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>
  <p id="no-results" hidden>No passports match your filter. Try a country name like Portugal, or a code like PRT.</p>
  </div>

  <style>
    .crumbs {
      font-size: 13px;
      color: var(--color-graphite);
      margin-bottom: 12px;
    }
    .crumbs span { margin: 0 6px; }
    .crumbs [aria-current] { margin: 0; }
    /* Captions are indexable text, but the tables are already titled by their h2. */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
      border: 0;
    }
  </style>

  <script>
    import { initSortableTable } from '../../lib/table-ui.ts';

    // Module scripts run once per session under the client router; page-load
    // fires again after every swap, re-binding against the fresh DOM. On other
    // pages the element guards make this call a no-op.
    document.addEventListener('astro:page-load', () => {
      initSortableTable({
        table: '#holders',
        filter: '#filter',
        noResults: '#no-results',
        initialSort: 'credit',
        defaultAsc: { credit: false, name: true, rank: true, score: false },
      });
    });
  </script>
</Base>
