---
import Base from '../layouts/Base.astro';
import openness from '../data/openness.json';
import { displayName, flagEmoji, fmt, searchIndex, tiedRanks } from '../lib/format.ts';
import { averageOpenness, openToAllCount, openToHalfCount, openToNoneCount } from '../lib/doors.ts';
import { absUrl, pageId, ID } from '../lib/seo.ts';
import Flag from '../components/Flag.astro';
const base = import.meta.env.BASE_URL;
const dests = openness.destinations;
// Repeated rank values are real ties and get the same "=" mark as the rankings.
const ties = tiedRanks(dests.map((d) => d.rank));
const mostOpen = dests[0];
const leastOpen = dests[dests.length - 1];

// The wall's three readings — fully open, majority open, shut — are computed
// from the data so the rail's copy can never drift from the wall it counts.
const scores = dests.map((d) => d.score);
const allCount = openToAllCount(scores);
const halfCount = openToHalfCount(scores);
const noneCount = openToNoneCount(scores);
// The headline's door is poured to the world's average — computed, like the
// rail's counts, so the device can never drift from the wall it fronts.
const avgOpen = Math.round(averageOpenness(scores));
const tipFor = (d: (typeof dests)[number]) =>
  `${flagEmoji(d.iso2)} ${displayName(d.iso3, d.name)} · openness ${fmt(d.score)} · ${ties.has(d.rank) ? '=' : ''}#${d.rank} of ${dests.length}`;

const rankingId = pageId(Astro.url.pathname, 'ranking');
const itemList = {
  '@type': 'ItemList',
  '@id': rankingId,
  name: 'Destinations by openness',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: dests.length,
  // subjectOf rather than about, and a list ordinal rather than d.rank — see the note on
  // the same node in index.astro. Openness ranks tie harder still: 199 destinations over
  // 139 distinct ranks.
  subjectOf: { '@id': ID.dataset },
  itemListElement: dests.map((d, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: absUrl(`${base}destination/${d.iso3.toLowerCase()}/`),
    name: `Who can enter ${displayName(d.iso3, d.name)}`,
  })),
};
---
<Base
  title="Openness: which passports get in - Pyatkov Index"
  description="Every destination ranked by the share of the world's people it admits at the border, an eVisa counting a fifth."
  mainEntityId={rankingId}
  jsonld={itemList}
>
  <section class="doors" aria-label="How open the world's destinations are">
    <div class="hero doors-lede">
      <h1>Who gets <span class="door-word" style={`--h:${avgOpen}%`}>in</span></h1>
      <p class="tagline">
        {`The index run backwards: not where a passport gets to, but whom a destination lets in. ${displayName(mostOpen.iso3, mostOpen.name)} admits practically everyone; ${displayName(leastOpen.iso3, leastOpen.name)}, no one.`}
      </p>
      <div class="doors-read">
        <div class="ds ds-all"><span class="ds-plate"><strong>{allCount}</strong></span><span class="ds-label">open to practically everyone</span></div>
        <div class="ds ds-half"><span class="ds-plate"><strong>{halfCount}</strong></span><span class="ds-label">open to more than half the world</span></div>
        <div class="ds ds-none"><span class="ds-plate"><strong>{noneCount}</strong></span><span class="ds-label">open to no one</span></div>
        <p class="doors-note">
          One door per destination, most open first — the fill is the share of the
          world it admits. The headline's door is the world average: {avgOpen}%
          open. <a href={`${base}methodology/`}>How scores work</a>
        </p>
      </div>
    </div>
    <div class="doors-figure">
      <div
        class="doors-wall"
        role="img"
        aria-label={`All ${dests.length} destinations as doors, most open first. Each door fills with the share of the world's people, outside its own borders, the destination admits at the border, an eVisa counting a fifth: ${allCount} doors are open to practically everyone, ${halfCount} to more than half the world, and ${noneCount} to no one.`}
      >
        {dests.map((d, i) => (
          <a
            class:list={['door', d.score > 50 && 'd-half', d.score >= 99.95 && 'd-all', d.score < 0.05 && 'd-none']}
            href={`${base}destination/${d.iso3.toLowerCase()}/`}
            data-tip={tipFor(d)}
            style={`--i:${i};--h:${d.score.toFixed(2)}%`}
          >
            <span class="sr-only">{displayName(d.iso3, d.name)} — openness {fmt(d.score)}</span>
          </a>
        ))}
      </div>
      <div class="ribbon-tip" aria-hidden="true" hidden></div>
    </div>
  </section>

  <div class="card card-mockup">
  <div class="card-header">
    <h2>Every destination, by openness</h2>
    <span class="count">{dests.length} destinations</span>
    <input type="search" id="filter" placeholder="Filter destinations" aria-label="Filter destinations" />
  </div>
  <div class="table-scroll">
  <table id="openness-table" class="rank-table">
    <thead>
      <tr>
        <th scope="col" data-sort="rank" aria-sort="ascending" tabindex="0">#</th>
        <th scope="col" data-sort="name" tabindex="0">Destination</th>
        <th scope="col" data-sort="score" tabindex="0">Openness</th>
      </tr>
    </thead>
    <tbody>
      {dests.map((d) => (
        <tr data-name={displayName(d.iso3, d.name).toLowerCase()} data-search={searchIndex(d)} data-rank={d.rank} data-score={d.score} style={`--w:${d.score}%`}>
          <td>{ties.has(d.rank) && <span class="tie-mark" aria-hidden="true">=</span>}{d.rank}</td>
          <td><a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a><span class="code" aria-hidden="true">{d.iso3}</span></td>
          <td class="score-cell">{fmt(d.score)}</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>
  <p id="no-results" hidden>No destinations match your filter. Try a country name like Japan, or a code like JPN.</p>
  </div>

  <script>
    import { initSortableTable } from '../lib/table-ui.ts';
    import { initRibbonTip } from '../lib/ribbon-tip.ts';

    // Module scripts run once per session under the client router; page-load
    // fires again after every swap, re-binding against the fresh DOM. On other
    // pages the element guards make these calls no-ops.
    document.addEventListener('astro:page-load', () => {
      initRibbonTip({ figure: '.doors-figure', ribbon: '.doors-wall', tip: '.doors-figure .ribbon-tip' });
      initSortableTable({
        table: '#openness-table',
        filter: '#filter',
        noResults: '#no-results',
        initialSort: 'rank',
        defaultAsc: { rank: true, name: true, score: false },
      });
    });
  </script>

  <style>
    /* global.css carries no visually-hidden utility; the doors' anchor text
       needs one, defined here next to its only users — the same arrangement
       as the front page's ribbon. */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }
  </style>
</Base>
