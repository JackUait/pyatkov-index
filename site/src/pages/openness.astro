---
import Base from '../layouts/Base.astro';
import openness from '../data/openness.json';
import { displayName, fmt, searchIndex } from '../lib/format.ts';
import Flag from '../components/Flag.astro';
const base = import.meta.env.BASE_URL;
const dests = openness.destinations;
const mostOpen = dests[0];
const leastOpen = dests[dests.length - 1];
---
<Base title="Openness: which passports get in - Pyatkov Index" description="Every destination ranked by the share of the world's people who can enter it without a prior visa.">
  <section class="hero">
    <h1>Who gets <span class="pill-word">in</span></h1>
    <p class="tagline">
      The index run backwards: every destination scored by the share of the world's people, outside
      its own borders, who can enter it without applying for a visa first.
    </p>
  </section>

  <section class="statline" aria-label="Openness coverage">
    <div><strong>{dests.length}</strong><span>destinations rated</span></div>
    <div><strong>{fmt(mostOpen.score)}</strong><span>most open ({displayName(mostOpen.iso3, mostOpen.name)})</span></div>
    <div><strong>{fmt(leastOpen.score)}</strong><span>least open ({displayName(leastOpen.iso3, leastOpen.name)})</span></div>
  </section>

  <p class="table-intro">
    Each destination scores 0 to 100 by the credit-weighted share of the world's foreign population
    holding a passport that can enter it: full credit for visa-free and visa on arrival, nothing for an
    eVisa or a visa requirement. A destination's own citizens are left out entirely — every
    country admits them, so they measure nothing. Pick any destination to see exactly which
    passports get which access.
  </p>

  <div class="card card-mockup">
  <div class="card-header">
    <h2>Every destination, by openness</h2>
    <span class="count">{dests.length} destinations</span>
    <input type="search" id="filter" placeholder="Filter destinations" aria-label="Filter destinations" />
  </div>
  <div class="table-scroll">
  <table id="openness-table" class="rank-table">
    <thead>
      <tr>
        <th scope="col" data-sort="rank" aria-sort="ascending" tabindex="0">#</th>
        <th scope="col" data-sort="name" tabindex="0">Destination</th>
        <th scope="col" data-sort="score" tabindex="0">Openness</th>
      </tr>
    </thead>
    <tbody>
      {dests.map((d) => (
        <tr data-name={displayName(d.iso3, d.name).toLowerCase()} data-search={searchIndex(d)} data-rank={d.rank} data-score={d.score}>
          <td>{d.rank}</td>
          <td><a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a></td>
          <td class="score-cell" style={`--w:${d.score}%`}>{fmt(d.score)}<span class="bar" aria-hidden="true"></span></td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>
  <p id="no-results" hidden>No destinations match your filter. Try a country name like Japan, or a code like JPN.</p>
  </div>

  <script>
    import { initSortableTable } from '../lib/table-ui.ts';

    // Module scripts run once per session under the client router; page-load
    // fires again after every swap, re-binding against the fresh DOM. On other
    // pages the element guards make this call a no-op.
    document.addEventListener('astro:page-load', () => {
      initSortableTable({
        table: '#openness-table',
        filter: '#filter',
        noResults: '#no-results',
        initialSort: 'rank',
        defaultAsc: { rank: true, name: true, score: false },
      });
    });
  </script>
</Base>
