---
import Base from '../../layouts/Base.astro';
import rankings from '../../data/rankings.json';
import weightsData from '../../data/weights.json';
import matrix from '../../data/matrix.json';
import { deltaLabel, displayName, flagEmoji, fmt, reconcilePoints } from '../../lib/format.ts';

export function getStaticPaths() {
  return rankings.passports.map((p) => ({ params: { iso3: p.iso3.toLowerCase() }, props: { passport: p } }));
}

const { passport: p } = Astro.props;
const base = import.meta.env.BASE_URL;
const access = (matrix as Record<string, Record<string, string>>)[p.iso3];
const CREDIT: Record<string, number> = { 'visa-free': 1.0, 'visa-on-arrival': 0.8, 'e-visa': 0.5, 'visa-required': 0 };
const LABEL: Record<string, string> = { 'visa-free': 'Visa-free', 'visa-on-arrival': 'Visa on arrival / eTA', 'e-visa': 'eVisa', 'visa-required': 'Visa required' };

// Foreign destinations only (exclude the home country) — used for the two
// "most valuable destination" lists, which shouldn't list the passport itself.
const foreignDests = weightsData.destinations
  .filter((d) => d.iso3 !== p.iso3)
  .map((d) => ({ ...d, category: access[d.iso3], contribution: CREDIT[access[d.iso3]] * d.weight }));
const reachable = foreignDests.filter((d) => d.category !== 'visa-required');
const topReachable = [...reachable].sort((a, b) => b.contribution - a.contribution).slice(0, 15);
const topMissing = foreignDests.filter((d) => d.category === 'visa-required').slice(0, 15); // already weight-desc
// Self-inclusion, consistent with the pipeline score: the home country is counted
// as a visa-free destination in BOTH numerator and denominator, so the tier points
// (which include the home country's own weight in the visa-free tier) sum to p.score
// before rounding, over the full destination pool.
const totalWeight = weightsData.destinations.reduce((a, d) => a + d.weight, 0);
const ownWeight = weightsData.destinations.find((d) => d.iso3 === p.iso3)?.weight ?? 0;
const denom = totalWeight;
const tierCats = Object.keys(LABEL);
const rawPoints = tierCats.map((cat) => {
  // The home country contributes its own weight to the visa-free tier (self-inclusion).
  const selfContribution = cat === 'visa-free' ? ownWeight : 0;
  const foreign = foreignDests.filter((d) => d.category === cat).reduce((a, d) => a + d.contribution, 0);
  return (100 * (foreign + selfContribution)) / denom;
});
// B5: round the tier points so they sum exactly to the displayed Score.
const reconciled = reconcilePoints(rawPoints, p.score);
const tierContribution = tierCats.map((cat, i) => ({
  cat,
  points: reconciled[i],
  count: p.counts[cat as keyof typeof p.counts],
}));

const name = displayName(p.iso3, p.name);
// Character-mark border: rotate through the reference's accent cast by rank.
const MARK_COLORS = ['var(--color-signal-blue)', 'var(--color-coral)', 'var(--color-marigold)', 'var(--color-sky-wash)'];
const markColor = MARK_COLORS[p.rank % MARK_COLORS.length];
---
<Base title={`${name} passport - Pyatkov Index`} description={`${name}: rank ${p.rank}, score ${fmt(p.score)} on the weighted passport index.`}>
  <section class="passport-hero">
    <span class="mark" style={`--mark-color:${markColor}`} aria-hidden="true">{flagEmoji(p.iso2)}</span>
    <h1>The {name} passport</h1>
  </section>

  <dl class="stats">
    <div><dt>Rank</dt><dd>#{p.rank}</dd></div>
    <div><dt>Score</dt><dd>{fmt(p.score)}</dd></div>
    <div><dt>Count rank</dt><dd>#{p.equalRank}</dd></div>
    <div><dt>Δ from weighting</dt><dd class={p.delta > 0 ? 'up' : p.delta < 0 ? 'down' : ''}>{deltaLabel(p.delta)}</dd></div>
  </dl>

  <h2>Where the score comes from</h2>
  <div class="card">
  <div class="table-scroll">
  <table class="tier-table">
    <thead><tr><th>Access tier</th><th>Destinations</th><th>Points</th></tr></thead>
    <tbody>
      {tierContribution.map((t) => (
        <tr><td><span class={`tag tag-${t.cat}`}>{LABEL[t.cat]}</span></td><td>{t.count}</td><td>{fmt(t.points)}</td></tr>
      ))}
    </tbody>
    <tfoot>
      <tr><th scope="row">Total (Score)</th><td>{p.counts['visa-free'] + p.counts['visa-on-arrival'] + p.counts['e-visa'] + p.counts['visa-required']}</td><td>{fmt(p.score)}</td></tr>
    </tfoot>
  </table>
  </div>
  </div>

  <div class="rank-cols">
    <section>
      <h2>Most valuable destinations reachable</h2>
      <ol class="rank-list">
        {topReachable.map((d) => (
          <li><a href={`${base}destination/${d.iso3.toLowerCase()}/`}>{flagEmoji(d.iso2)} {displayName(d.iso3, d.name)}</a> <span class="meta"><span class={`tag tag-${d.category}`}>{LABEL[d.category]}</span> weight {d.weight.toFixed(3)}</span></li>
        ))}
      </ol>
    </section>
    <section>
      <h2>Most valuable destinations missing</h2>
      {topMissing.length === 0 ? <p>None. This passport reaches every weighted destination.</p> : (
        <ol class="rank-list">
          {topMissing.map((d) => (
            <li><a href={`${base}destination/${d.iso3.toLowerCase()}/`}>{flagEmoji(d.iso2)} {displayName(d.iso3, d.name)}</a> <span class="meta">weight {d.weight.toFixed(3)}</span></li>
          ))}
        </ol>
      )}
    </section>
  </div>
</Base>
