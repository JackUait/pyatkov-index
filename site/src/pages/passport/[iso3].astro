---
import Base from '../../layouts/Base.astro';
import rankings from '../../data/rankings.json';
import openness from '../../data/openness.json';
import weightsData from '../../data/weights.json';
import matrix from '../../data/matrix.json';
import { bareName, displayName, fmt, reconcilePoints, verbFor, withArticle } from '../../lib/format.ts';
import { CREDIT, LABEL, TIERS, type Tier } from '../../lib/credit.ts';
import { ID, pageId } from '../../lib/seo.ts';
import { countryNode } from '../../lib/schema.ts';
import Flag from '../../components/Flag.astro';

export function getStaticPaths() {
  return rankings.passports.map((p) => ({ params: { iso3: p.iso3.toLowerCase() }, props: { passport: p } }));
}

const { passport: p } = Astro.props;
const base = import.meta.env.BASE_URL;
const access = (matrix as Record<string, Record<string, string>>)[p.iso3];

// Foreign destinations only (exclude the home country) — used for the two
// "most valuable destination" lists, which shouldn't list the passport itself.
const foreignDests = weightsData.destinations
  .filter((d) => d.iso3 !== p.iso3)
  .map((d) => ({ ...d, category: access[d.iso3] as Tier, contribution: CREDIT[access[d.iso3] as Tier] * d.weight }));
// Open/closed is the credit ladder, not the tier name: an eVisa earns nothing, so it
// belongs in the "missing" column even though the destination does admit the holder.
const reachable = foreignDests.filter((d) => CREDIT[d.category] > 0);
const topReachable = [...reachable].sort((a, b) => b.contribution - a.contribution).slice(0, 15);
const topMissing = foreignDests.filter((d) => CREDIT[d.category] === 0).slice(0, 15); // already weight-desc
// Self-inclusion, consistent with the pipeline score: the home country is counted
// as a visa-free destination in BOTH numerator and denominator, so the tier points
// (which include the home country's own weight in the visa-free tier) sum to p.score
// before rounding, over the full destination pool.
const totalWeight = weightsData.destinations.reduce((a, d) => a + d.weight, 0);
const ownWeight = weightsData.destinations.find((d) => d.iso3 === p.iso3)?.weight ?? 0;
const denom = totalWeight;
const rawPoints = TIERS.map((cat) => {
  // The home country contributes its own weight to the visa-free tier (self-inclusion).
  const selfContribution = cat === 'visa-free' ? ownWeight : 0;
  const foreign = foreignDests.filter((d) => d.category === cat).reduce((a, d) => a + d.contribution, 0);
  return (100 * (foreign + selfContribution)) / denom;
});
// B5: round the tier points so they sum exactly to the displayed Score.
const reconciled = reconcilePoints(rawPoints, p.score);
const tierContribution = TIERS.map((cat, i) => ({
  cat,
  points: reconciled[i],
  count: p.counts[cat as keyof typeof p.counts],
}));

const name = displayName(p.iso3, p.name);
// The same name where it lands as a sentence subject or after a preposition, which is
// where "is United States" reads as a template tell. Attributive uses ("the {name}
// passport", "{name} holders") keep the bare form.
const theName = withArticle(p.iso3, p.name);
// And the form for the two slots that write their own "The" — otherwise BHS and GMB,
// whose display names carry an article, read "The The Bahamas passport".
const bare = bareName(p.iso3, p.name);
const total = rankings.passports.length;

const ordinal = (n: number) => {
  const rem100 = n % 100;
  if (rem100 >= 11 && rem100 <= 13) return `${n}th`;
  return `${n}${['th', 'st', 'nd', 'rd'][n % 10] ?? 'th'}`;
};
const places = (n: number) => `${n} ${n === 1 ? 'place' : 'places'}`;
// Where a destination sits in the weight table, for prose like "the 4th heaviest".
const weightRank = (iso3: string) => weightsData.destinations.findIndex((w) => w.iso3 === iso3) + 1;
const sharePoints = (weight: number) => fmt((100 * weight) / totalWeight);

// A shift this small is inside the noise of a densely tied count rank, so it gets no
// causal story: attaching the full "its reach is to destinations that carry little
// weight" clause to a one-place move said exactly that about Singapore, which is #3 and
// reaches every heavy destination there is.
const NEAR_TIE = 2;
const deltaSentence =
  p.delta === 0
    ? `A plain destination count puts it at #${p.equalRank} as well, so the weighting neither flatters nor punishes it: its access is spread across the value scale in about the proportion a headcount would suggest.`
    : Math.abs(p.delta) <= NEAR_TIE
      ? `A plain destination count would put it at #${p.equalRank}, so weighting ${p.delta > 0 ? 'lifts' : 'costs'} it ${places(Math.abs(p.delta))} — close enough that the two orderings agree about where it belongs.`
      : p.delta > 0
        ? `A plain destination count would put it at #${p.equalRank}, so weighting lifts it ${places(p.delta)} — the countries it reaches are disproportionately valuable ones, the large economies and heavily visited destinations that carry most of the index's weight.`
        : `A plain destination count would put it at #${p.equalRank}, so weighting costs it ${places(-p.delta)} — much of its reach is to destinations that carry little economic, tourist, or diaspora weight, while heavier ones stay closed.`;

// Prose is assembled here rather than inline: the template strips the whitespace
// between an expression and the text on the next line, and these sentences wrap.
const lede =
  `The ${bare} passport scores ${fmt(p.score)} out of 100 on the Pyatkov Index, which ranks it ` +
  `#${p.rank} of ${total}. Of the ${rankings.totalDestinations} destinations the index scores, it enters ` +
  `${p.counts['visa-free']} visa-free and ${p.counts['visa-on-arrival']} on arrival; ${p.counts['e-visa']} ` +
  `${verbFor(p.counts['e-visa'], 'offer')} an eVisa, which this index counts as closed because it has to ` +
  `clear before departure, and ${p.counts['visa-required']} ` +
  `${verbFor(p.counts['visa-required'], 'require')} a visa arranged in advance. ${deltaSentence}`;

const best = topReachable[0];
const gap = topMissing[0];
const bestSentence = best
  ? `Its most valuable open destination is ${withArticle(best.iso3, best.name)} — weight ` +
    `${best.weight.toFixed(3)}, the ${ordinal(weightRank(best.iso3))} heaviest in the index — which ` +
    `${name} holders enter ${best.category === 'visa-free' ? 'visa-free' : 'on arrival'}, worth ` +
    `${sharePoints(best.weight)} points on its own.`
  : '';
const gapSentence = gap
  ? `The most valuable one still closed to them is ${withArticle(gap.iso3, gap.name)}, the ` +
    `${ordinal(weightRank(gap.iso3))} heaviest at weight ${gap.weight.toFixed(3)}: it ` +
    `${gap.category === 'e-visa' ? 'issues an eVisa that has to be approved before boarding' : 'requires a visa arranged in advance'}, ` +
    `so it adds nothing here. Opening that one destination would move the score by ${sharePoints(gap.weight)} points.`
  : 'Nothing is left out: every weighted destination admits this passport without prior permission.';
// The mirror view: how the country does as a destination. On near-identical passports
// (the Schengen pairs) this is where the numbers actually diverge.
const ownDest = openness.destinations.find((x) => x.iso3 === p.iso3);
const mirrorSentence = ownDest
  ? `Read the other way round, ${theName} is itself the ${ordinal(weightRank(p.iso3))} heaviest destination ` +
    `in the index at weight ${ownWeight.toFixed(3)}, and the ${ordinal(ownDest.rank)} most open: ` +
    `${fmt(ownDest.score)} out of 100 of the world's people outside it can arrive without a prior visa.`
  : '';
const reachableIntro =
  `Weight is a destination's share of the world's destination value — its economy, inbound arrivals, ` +
  `human development and migrant stock, normalised and combined — so these are the ${reachable.length} ` +
  `open destinations that put the most into the ${fmt(p.score)} above.`;
const missingIntro =
  `The heaviest destinations that need permission before departure, eVisas included. Each one's weight ` +
  `is roughly the points it would add to ${name}'s score if that permission were dropped.`;

const countryId = pageId(Astro.url.pathname, 'country');
const country = countryNode({
  id: countryId,
  name,
  iso3: p.iso3,
  iso2: p.iso2,
  // Names and propertyIDs are qualified with "passport": the destination page emits a
  // Country node for the same country carrying its OWN count rank and delta, and a
  // consumer merging the two graphs by property name would otherwise read the passport's
  // #76 and the destination's #1 as two values of one thing.
  measures: [
    { propertyID: 'pyatkov-score', name: 'Pyatkov score', value: Number(fmt(p.score)), minValue: 0, maxValue: 100 },
    { propertyID: 'passport-rank', name: 'Passport rank', value: p.rank },
    { propertyID: 'passport-count-rank', name: 'Passport count rank', value: p.equalRank },
    { propertyID: 'passport-delta', name: 'Passport delta from weighting', value: p.delta },
  ],
});

// Character-mark border: rotate through the reference's accent cast by rank.
const MARK_COLORS = ['var(--color-signal-blue)', 'var(--color-coral)', 'var(--color-marigold)', 'var(--color-sky-wash)'];
const markColor = MARK_COLORS[p.rank % MARK_COLORS.length];
---
<Base
  title={`${name} passport - Pyatkov Index`}
  description={`${name} passport: rank #${p.rank} of ${total}, score ${fmt(p.score)}/100. Visa-free to ${p.counts['visa-free']}, on arrival to ${p.counts['visa-on-arrival']}; ${p.counts['e-visa']} eVisa and ${p.counts['visa-required']} visa-required count as closed.`}
  ogType="article"
  breadcrumb={[{ name: 'Rankings', href: base }, { name: `${name} passport` }]}
  mainEntityId={countryId}
  basedOnId={ID.dataset}
  jsonld={country}
>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href={base}>Rankings</a> <span aria-hidden="true">/</span> <span aria-current="page">{name} passport</span>
  </nav>

  <section class="passport-hero">
    <span class="mark" style={`--mark-color:${markColor}`} aria-hidden="true"><Flag iso2={p.iso2} class="flag-mark" /></span>
    <h1>The {bare} passport</h1>
  </section>

  <dl class="stats">
    <div><dt>Rank</dt><dd>#{p.rank}</dd></div>
    <div><dt>Score</dt><dd>{fmt(p.score)}</dd></div>
    <div><dt><a href={`${base}methodology/#count-rank`}>Count rank</a></dt><dd>#{p.equalRank}</dd></div>
  </dl>

  <p class="lede">{lede}</p>

  <p>{bestSentence} {gapSentence} {mirrorSentence}</p>

  <h2>Where the score comes from</h2>
  <div class="card">
  <div class="table-scroll">
  <table class="tier-table">
    <caption class="sr-only">How {name}'s score of {fmt(p.score)} splits across the four access tiers</caption>
    <thead><tr><th scope="col">Access tier</th><th scope="col">Destinations</th><th scope="col">Points</th></tr></thead>
    <tbody>
      {tierContribution.map((t) => (
        <tr><td><span class={`tag tag-${t.cat}`}>{LABEL[t.cat]}</span></td><td>{t.count}</td><td>{fmt(t.points)}</td></tr>
      ))}
    </tbody>
    <tfoot>
      <tr><th scope="row">Total (Score)</th><td>{p.counts['visa-free'] + p.counts['visa-on-arrival'] + p.counts['e-visa'] + p.counts['visa-required']}</td><td>{fmt(p.score)}</td></tr>
    </tfoot>
  </table>
  </div>
  </div>

  <div class="rank-cols">
    <section>
      <h2>Most valuable destinations reachable</h2>
      <p class="list-intro">{reachableIntro}</p>
      <ol class="rank-list">
        {topReachable.map((d) => (
          <li><a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a> <span class="meta"><span class={`tag tag-${d.category}`}>{LABEL[d.category]}</span> weight {d.weight.toFixed(3)}</span></li>
        ))}
      </ol>
    </section>
    <section>
      <h2>Most valuable destinations missing</h2>
      {topMissing.length === 0 ? <p>None. This passport reaches every weighted destination.</p> : (
        <Fragment>
          <p class="list-intro">{missingIntro}</p>
          <ol class="rank-list">
            {topMissing.map((d) => (
              <li><a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a> <span class="meta"><span class={`tag tag-${d.category}`}>{LABEL[d.category]}</span> weight {d.weight.toFixed(3)}</span></li>
            ))}
          </ol>
        </Fragment>
      )}
    </section>
  </div>

  <p class="closing">
    All {total} passports are scored the same way: see the <a href={base}>full ranking</a>, read <a href={`${base}methodology/`}>how the weights are built</a>, or turn the question around and <a href={`${base}destination/${p.iso3.toLowerCase()}/`}>see who can enter {theName}</a>.
  </p>

  <style>
    .crumbs {
      font-size: 13px;
      color: var(--color-graphite);
      margin-bottom: 12px;
    }
    .crumbs span { margin: 0 6px; }
    .crumbs [aria-current] { margin: 0; }
    .list-intro {
      font-size: 14px;
      color: var(--color-graphite);
      max-width: 46ch;
    }
    .closing { margin-top: 40px; }
    /* Captions are indexable text, but the tables are already titled by their h2. */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
      border: 0;
    }
  </style>
</Base>
