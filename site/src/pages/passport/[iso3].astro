---
import Base from '../../layouts/Base.astro';
import rankings from '../../data/rankings.json';
import openness from '../../data/openness.json';
import weightsData from '../../data/weights.json';
import matrix from '../../data/matrix.json';
import { bareName, displayName, fmt, reconcilePoints, searchIndex, withArticle } from '../../lib/format.ts';
import { CREDIT, LABEL, TIERS, type Tier } from '../../lib/credit.ts';
import { ID, pageId } from '../../lib/seo.ts';
import { countryNode } from '../../lib/schema.ts';
import Flag from '../../components/Flag.astro';

export function getStaticPaths() {
  return rankings.passports.map((p) => ({ params: { iso3: p.iso3.toLowerCase() }, props: { passport: p } }));
}

const { passport: p } = Astro.props;
const base = import.meta.env.BASE_URL;
const access = (matrix as Record<string, Record<string, string>>)[p.iso3];

// Foreign destinations only (exclude the home country) — used for the two
// "heaviest doors" lists, which shouldn't list the passport itself.
const foreignDests = weightsData.destinations
  .filter((d) => d.iso3 !== p.iso3)
  .map((d) => ({ ...d, category: access[d.iso3] as Tier, contribution: CREDIT[access[d.iso3] as Tier] * d.weight }));
// Open/closed is the credit ladder, not the tier name: an eVisa earns nothing, so it
// belongs in the "closed" column even though the destination does admit the holder.
const reachable = foreignDests.filter((d) => CREDIT[d.category] > 0);
const topReachable = [...reachable].sort((a, b) => b.contribution - a.contribution).slice(0, 15);
const topMissing = foreignDests.filter((d) => CREDIT[d.category] === 0).slice(0, 15); // already weight-desc
// Self-inclusion, consistent with the pipeline score: the home country is counted
// as a visa-free destination in BOTH numerator and denominator, so the tier points
// (which include the home country's own weight in the visa-free tier) sum to p.score
// before rounding, over the full destination pool.
const totalWeight = weightsData.destinations.reduce((a, d) => a + d.weight, 0);
const ownWeight = weightsData.destinations.find((d) => d.iso3 === p.iso3)?.weight ?? 0;
const denom = totalWeight;
const rawPoints = TIERS.map((cat) => {
  // The home country contributes its own weight to the visa-free tier (self-inclusion).
  const selfContribution = cat === 'visa-free' ? ownWeight : 0;
  const foreign = foreignDests.filter((d) => d.category === cat).reduce((a, d) => a + d.contribution, 0);
  return (100 * (foreign + selfContribution)) / denom;
});
// B5: round the tier points so they sum exactly to the displayed Score.
const reconciled = reconcilePoints(rawPoints, p.score);
const tierContribution = TIERS.map((cat, i) => ({
  cat,
  points: reconciled[i],
  count: p.counts[cat as keyof typeof p.counts],
}));

const name = displayName(p.iso3, p.name);
// The name where it lands after a preposition ("who can enter …"), which is where
// "enter United States" reads as a template tell.
const theName = withArticle(p.iso3, p.name);
// And the form for the slot that writes its own "The" — otherwise BHS and GMB,
// whose display names carry an article, read "The The Bahamas passport".
const bare = bareName(p.iso3, p.name);
const total = rankings.passports.length;

// Where a destination sits in the weight table, for the mirror statline.
const weightRank = (iso3: string) => weightsData.destinations.findIndex((w) => w.iso3 === iso3) + 1;
// Weight as points: credit for both open tiers is 1.0, so a destination's share of
// the total weight is exactly what it pays into the score — or would, if opened.
const sharePoints = (weight: number) => fmt((100 * weight) / denom);

// The delta from weighting, folded into the count-rank tile as a one-line note.
const places = (n: number) => `${n} ${n === 1 ? 'place' : 'places'}`;
const deltaNote =
  p.delta === 0
    ? 'matches the weighted rank'
    : p.delta > 0
      ? `weighting lifts it ${places(p.delta)}`
      : `weighting costs it ${places(-p.delta)}`;

// Score anatomy bar: the two earning tiers at their (reconciled) points, the two
// closed tiers at the points they withhold — together the segments span 100.
const potential = (cat: Tier) =>
  (100 * foreignDests.filter((d) => d.category === cat).reduce((a, d) => a + d.weight, 0)) / denom;
const segments = tierContribution
  .map((t) => ({ cat: t.cat, share: CREDIT[t.cat] > 0 ? t.points : potential(t.cat) }))
  .filter((s) => s.share > 0.05);
const locked = potential('e-visa') + potential('visa-required');
const barLabel = segments
  .map((s) => `${LABEL[s.cat]}: ${fmt(s.share)} points ${CREDIT[s.cat] > 0 ? 'earned' : 'locked'}`)
  .join(', ');

// The two doors that matter most, pulled out as cards.
const best = topReachable[0];
const gap = topMissing[0];

// Weight meters in the lists share one scale across both columns, so the
// open/closed asymmetry stays visible.
const maxListWeight = Math.max(...[...topReachable, ...topMissing].map((d) => d.weight), ownWeight, 1e-9);
const meterWidth = (weight: number) => `${Math.max(2, (100 * weight) / maxListWeight).toFixed(1)}%`;

// The mirror view: how the country does as a destination. On near-identical
// passports (the Schengen pairs) this is where the numbers actually diverge.
const ownDest = openness.destinations.find((x) => x.iso3 === p.iso3);

const countryId = pageId(Astro.url.pathname, 'country');
const country = countryNode({
  id: countryId,
  name,
  iso3: p.iso3,
  iso2: p.iso2,
  // Names and propertyIDs are qualified with "passport": the destination page emits a
  // Country node for the same country carrying its OWN count rank and delta, and a
  // consumer merging the two graphs by property name would otherwise read the passport's
  // #76 and the destination's #1 as two values of one thing.
  measures: [
    { propertyID: 'pyatkov-score', name: 'Pyatkov score', value: Number(fmt(p.score)), minValue: 0, maxValue: 100 },
    { propertyID: 'passport-rank', name: 'Passport rank', value: p.rank },
    { propertyID: 'passport-count-rank', name: 'Passport count rank', value: p.equalRank },
    { propertyID: 'passport-delta', name: 'Passport delta from weighting', value: p.delta },
  ],
});

// Character-mark border: rotate through the reference's accent cast by rank.
const MARK_COLORS = ['var(--color-signal-blue)', 'var(--color-coral)', 'var(--color-marigold)', 'var(--color-sky-wash)'];
const markColor = MARK_COLORS[p.rank % MARK_COLORS.length];
---
<Base
  title={`${name} passport - Pyatkov Index`}
  description={`${name} passport: rank #${p.rank} of ${total}, score ${fmt(p.score)}/100. Visa-free to ${p.counts['visa-free']}, on arrival to ${p.counts['visa-on-arrival']}; ${p.counts['e-visa']} eVisa and ${p.counts['visa-required']} visa-required count as closed.`}
  ogType="article"
  breadcrumb={[{ name: 'Rankings', href: base }, { name: `${name} passport` }]}
  mainEntityId={countryId}
  basedOnId={ID.dataset}
  jsonld={country}
>
  <nav class="crumbs" aria-label="Breadcrumb">
    <a href={base}>Rankings</a> <span aria-hidden="true">/</span> <span aria-current="page">{name} passport</span>
  </nav>

  <section class="passport-hero">
    <span class="mark" style={`--mark-color:${markColor}`} aria-hidden="true"><Flag iso2={p.iso2} class="flag-mark" /></span>
    <h1>The {bare} passport</h1>
  </section>

  <dl class="stats">
    <div><dt>Rank</dt><dd>#{p.rank}</dd></div>
    <div><dt>Score</dt><dd>{fmt(p.score)}</dd></div>
    <div>
      <dt><a href={`${base}methodology/#count-rank`}>Count rank</a></dt>
      <dd>#{p.equalRank} <span class="stat-note">{deltaNote}</span></dd>
    </div>
  </dl>

  <h2>Where the score comes from</h2>
  <div class="card">
    <div class="score-anatomy">
      <div class="bar-annot">
        <span><b>{fmt(p.score)}</b> points earned</span>
        {locked > 0.05 && <span><b>{fmt(locked)}</b> points locked</span>}
      </div>
      <div class="score-bar" role="img" aria-label={barLabel}>
        {segments.map((s) => (
          <i class={`tier-${s.cat}`} style={`--share:${s.share.toFixed(2)}`} />
        ))}
      </div>
    </div>
    <div class="table-scroll">
      <table class="tier-table">
        <caption class="sr-only">How {name}'s score of {fmt(p.score)} splits across the four access tiers</caption>
        <thead><tr><th scope="col">Access tier</th><th scope="col">Destinations</th><th scope="col">Points</th></tr></thead>
        <tbody>
          {tierContribution.map((t) => (
            <tr><td><span class={`tier-key tier-${t.cat}`}>{LABEL[t.cat]}</span></td><td>{t.count}</td><td>{fmt(t.points)}</td></tr>
          ))}
        </tbody>
        <tfoot>
          <tr><th scope="row">Total (Score)</th><td>{p.counts['visa-free'] + p.counts['visa-on-arrival'] + p.counts['e-visa'] + p.counts['visa-required']}</td><td>{fmt(p.score)}</td></tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="hl-grid">
    {best && (
      <div class="hl-card hl-open">
        <span class="hl-label">Best open door</span>
        <a class="hl-name" href={`${base}destination/${best.iso3.toLowerCase()}/`}><Flag iso2={best.iso2} /> {displayName(best.iso3, best.name)}</a>
        <span class={`tier-key tier-${best.category}`}>{LABEL[best.category]}</span>
        <span class="hl-pts"><b>{sharePoints(best.weight)}</b> points of the score</span>
      </div>
    )}
    <div class="hl-card hl-locked">
      {gap ? (
        <Fragment>
          <span class="hl-label">Costliest closed door</span>
          <a class="hl-name" href={`${base}destination/${gap.iso3.toLowerCase()}/`}><Flag iso2={gap.iso2} /> {displayName(gap.iso3, gap.name)}</a>
          <span class={`tier-key tier-${gap.category}`}>{LABEL[gap.category]}</span>
          <span class="hl-pts"><b>+{sharePoints(gap.weight)}</b> points if it opened</span>
        </Fragment>
      ) : (
        <Fragment>
          <span class="hl-label">Nothing closed</span>
          <p class="hl-none">Every weighted destination admits {name} holders without prior permission.</p>
        </Fragment>
      )}
    </div>
  </div>

  <div class="rank-cols">
    <section>
      <h2>The heaviest open doors</h2>
      <p class="list-intro">Top {topReachable.length} of {reachable.length} open destinations, by the points each pays into the score.</p>
      <ol class="rank-list">
        {topReachable.map((d) => (
          <li>
            <a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a>
            <span class={`wt tier-${d.category}`} title={LABEL[d.category]}>
              <span class="sr-only">{LABEL[d.category]},</span>
              <i class="wt-meter" style={`--w:${meterWidth(d.weight)}`} aria-hidden="true"></i>
              <b class="wt-val">{sharePoints(d.weight)}</b>
            </span>
          </li>
        ))}
      </ol>
    </section>
    <section>
      <h2>The heaviest closed doors</h2>
      {topMissing.length === 0 ? <p class="list-intro">None — this passport reaches every weighted destination.</p> : (
        <Fragment>
          <p class="list-intro">Still need permission before departure — and the points each would add if it opened.</p>
          <ol class="rank-list">
            {topMissing.map((d) => (
              <li>
                <a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a>
                <span class={`wt tier-${d.category}`} title={LABEL[d.category]}>
                  <span class="sr-only">{LABEL[d.category]},</span>
                  <i class="wt-meter" style={`--w:${meterWidth(d.weight)}`} aria-hidden="true"></i>
                  <b class="wt-val">+{sharePoints(d.weight)}</b>
                </span>
              </li>
            ))}
          </ol>
        </Fragment>
      )}
    </section>
  </div>

  <div class="dest-map-head">
    <h2>Every destination</h2>
    <input
      id="dest-search"
      class="dest-search"
      type="search"
      placeholder={`Search ${foreignDests.length} destinations`}
      aria-label="Search destinations"
      autocomplete="off"
    />
  </div>
  <div class="dest-map">
    {TIERS.map((cat) => {
      const items = foreignDests
        .filter((d) => d.category === cat)
        .map((d) => ({ ...d, label: displayName(d.iso3, d.name) }))
        .sort((a, b) => a.label.localeCompare(b.label, 'en'));
      const points = tierContribution.find((t) => t.cat === cat)?.points ?? 0;
      return (
        items.length > 0 && (
          <section class="dest-group">
            <header class="dest-head">
              <h3 class={`tier-key tier-${cat}`}>{LABEL[cat]} <span class="count">{items.length}</span></h3>
              <span class="dest-pts">{fmt(points)} points</span>
            </header>
            <ul class={`dest-flow tier-${cat}${CREDIT[cat] > 0 ? '' : ' is-locked'}`}>
              {items.map((d) => (
                <li data-search={searchIndex(d)}><a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {d.label}</a></li>
              ))}
            </ul>
          </section>
        )
      );
    })}
    <p class="dest-empty" hidden>No destination matches that search.</p>
  </div>

  {ownDest && (
    <Fragment>
      <h2>As a destination</h2>
      <div class="statline">
        <div><strong>#{weightRank(p.iso3)}</strong> <span>heaviest in the index · weight {ownWeight.toFixed(3)}</span></div>
        <div><strong>#{ownDest.rank}</strong> <span>most open of {openness.destinations.length}</span></div>
        <div><strong>{fmt(ownDest.score)}</strong> <span>openness score / 100</span></div>
        <div class="stat-end"><a href={`${base}destination/${p.iso3.toLowerCase()}/`}>Who can enter {theName} →</a></div>
      </div>
    </Fragment>
  )}

  <style>
    .crumbs {
      font-size: 13px;
      color: var(--color-graphite);
      margin-bottom: 12px;
    }
    .crumbs span { margin: 0 6px; }
    .crumbs [aria-current] { margin: 0; }
    .list-intro {
      font-size: 14px;
      color: var(--color-graphite);
      max-width: 46ch;
    }
    /* Captions are indexable text, but the tables are already titled by their h2. */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
      border: 0;
    }
  </style>

  {/* astro:page-load fires on the initial load too (ClientRouter), so one
      listener covers first paint and every view transition. In the drawer the
      page's scripts arrive inert; country-drawer.ts re-runs the init there. */}
  <script>
    import { initDestSearch } from '../../lib/dest-search.ts';
    document.addEventListener('astro:page-load', () => initDestSearch());
  </script>
</Base>
