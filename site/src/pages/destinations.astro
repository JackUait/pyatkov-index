---
import Base from '../layouts/Base.astro';
import weightsData from '../data/weights.json';
import { displayName } from '../lib/format.ts';
import { absUrl, pageId, ID } from '../lib/seo.ts';
import Flag from '../components/Flag.astro';
const base = import.meta.env.BASE_URL;
// Signal columns are per-signal z-scores (standard deviations from the
// destination average), so they are signed; a middle dot marks a missing signal.
const z = (v: number | null) => (v === null ? '·' : (v >= 0 ? '+' : '') + v.toFixed(2));

const rankingId = pageId(Astro.url.pathname, 'ranking');
// weightsData.destinations arrives weight-sorted, so the row index is the position.
const itemList = {
  '@type': 'ItemList',
  '@id': rankingId,
  name: 'Destination weights',
  itemListOrder: 'https://schema.org/ItemListOrderDescending',
  numberOfItems: weightsData.destinations.length,
  // subjectOf rather than about — see the note on the same node in index.astro.
  subjectOf: { '@id': ID.dataset },
  itemListElement: weightsData.destinations.map((d, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: absUrl(`${base}destination/${d.iso3.toLowerCase()}/`),
    name: displayName(d.iso3, d.name),
  })),
};
---
<Base
  title="Destination weights - Pyatkov Index"
  description="How much each destination is worth in the Pyatkov Index, and why."
  wide
  mainEntityId={rankingId}
  jsonld={itemList}
>
  <h1>Destination weights</h1>
  <p class="lede">
    How much each destination is worth, and why. This table is the entire recipe: nothing is hidden.
  </p>
  <p>
    Each destination's weight is <code>exp(1.25 × Z)</code>, where <code>Z</code> is the mean of its
    available signal <em>z-scores</em>: how many standard deviations above or below average it sits on
    log-scaled GDP, log-scaled arrivals, HDI, and log-scaled migrant stock. The signal columns below show
    those z-scores (signed; <code>·</code> means that signal is missing for the destination).
  </p>
  <div class="card card-mockup">
  <div class="card-header">
    <h2>Every destination, weighted</h2>
    <span class="count">{weightsData.destinations.length} destinations</span>
  </div>
  <div class="table-scroll">
  <table class="weights-table">
    <caption class="sr-only">Every destination in the Pyatkov Index with its weight and the four z-scored signals behind it</caption>
    <thead>
      <tr><th scope="col">#</th><th scope="col">Destination</th><th scope="col">Weight</th><th scope="col">GDP</th><th scope="col">Arrivals</th><th scope="col">HDI</th><th scope="col">Migrants</th><th scope="col">Signals</th></tr>
    </thead>
    <tbody>
      {weightsData.destinations.map((d, i) => (
        <tr>
          <td>{i + 1}</td>
          <td><a href={`${base}destination/${d.iso3.toLowerCase()}/`}><Flag iso2={d.iso2} /> {displayName(d.iso3, d.name)}</a></td>
          <td>{d.weight.toFixed(3)}</td>
          <td>{z(d.normalized.gdp)}</td>
          <td>{z(d.normalized.arrivals)}</td>
          <td>{z(d.normalized.hdi)}</td>
          <td>{z(d.normalized.migrants)}</td>
          <td>{d.signalsUsed}/4</td>
        </tr>
      ))}
    </tbody>
  </table>
  </div>
  </div>

  <style>
    /* global.css carries no visually-hidden utility; the caption names the
       table for assistive tech without repeating the heading on screen. */
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }
  </style>
</Base>
