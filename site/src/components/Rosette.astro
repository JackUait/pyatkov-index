---
// Decorative guilloché rosette — the security-print ornament used on passport
// data pages. Pure stroke geometry, colored via currentColor so the page sets
// its tone; aria-hidden because it is ornament, never content.
const petals = Array.from({ length: 24 }, (_, i) => i * 15);
const spokes = Array.from({ length: 60 }, (_, i) => i * 6);
---
<svg
  class="rosette"
  viewBox="0 0 400 400"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
>
  <circle cx="200" cy="200" r="192" stroke-width="1" stroke-dasharray="1 5" />
  <circle cx="200" cy="200" r="178" stroke-width="0.75" />
  <circle cx="200" cy="200" r="172" stroke-width="0.75" stroke-dasharray="10 4" />
  <circle cx="200" cy="200" r="120" stroke-width="0.75" />
  <circle cx="200" cy="200" r="52" stroke-width="0.75" stroke-dasharray="3 3" />
  <circle cx="200" cy="200" r="40" stroke-width="0.75" />
  {petals.map((a) => (
    <ellipse cx="200" cy="200" rx="160" ry="34" stroke-width="0.6" transform={`rotate(${a} 200 200)`} />
  ))}
  {spokes.map((a) => (
    <line x1="200" y1="28" x2="200" y2="60" stroke-width="0.5" transform={`rotate(${a} 200 200)`} />
  ))}
</svg>
