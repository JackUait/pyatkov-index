---
import '@fontsource-variable/inter';
import '@fontsource/source-serif-pro/latin-400.css';
import '@fontsource/source-serif-pro/latin-400-italic.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { normalizePath } from '../lib/nav-current.ts';
import { absUrl, ID } from '../lib/seo.ts';
// The three faces the first screen actually paints. Imported for their URLs so the
// build's content hash is never hardcoded.
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import serifLatin from '@fontsource/source-serif-pro/files/source-serif-pro-latin-400-normal.woff2?url';
import serifLatinItalic from '@fontsource/source-serif-pro/files/source-serif-pro-latin-400-italic.woff2?url';

export interface Props {
  title: string;
  description: string;
  wide?: boolean;
  ogType?: 'website' | 'article';
  /** Base-relative path or absolute URL; resolved to absolute below. */
  image?: string;
  noindex?: boolean;
  /** Mirror of the page's VISIBLE breadcrumb. The last crumb gets no `item`, so the
   *  current page never self-links. */
  breadcrumb?: Array<{ name: string; href?: string }>;
  /** @id of this page's primary entity, from pageId(Astro.url.pathname, ...). */
  mainEntityId?: string;
  /** @id of the source this page's content is derived from — usually ID.dataset. It is
   *  emitted as isBasedOn on the WebPage node: isBasedOn domainIncludes CreativeWork
   *  only, so a Country/Place mainEntity cannot carry the provenance itself. */
  basedOnId?: string;
  /** Extra JSON-LD node(s), without '@context' — the graph root supplies it once. */
  jsonld?: unknown | unknown[];
}

const {
  title,
  description,
  wide = false,
  ogType = 'website',
  image,
  noindex = false,
  breadcrumb = [],
  mainEntityId,
  basedOnId,
  jsonld,
} = Astro.props;

if (import.meta.env.PROD && Astro.site?.hostname === 'example.github.io') {
  throw new Error('astro.config.mjs site is still the placeholder');
}

const base = import.meta.env.BASE_URL;

// Astro.url.pathname already carries the base — absUrl must not add it again.
const canonical = absUrl(Astro.url.pathname);
const ogImage = absUrl(image ?? `${base}og-default.png`);
const tagline =
  'Most passport rankings count destinations. The Pyatkov Index weights each one by the economy, travel, development, and diaspora behind it.';

const graph: unknown[] = [
  {
    '@type': 'WebSite',
    '@id': ID.website,
    url: absUrl(base),
    name: 'Pyatkov Index',
    alternateName: 'The Pyatkov Index',
    description: tagline,
    inLanguage: 'en',
    publisher: { '@id': ID.creator },
  },
  {
    '@type': 'Organization',
    '@id': ID.creator,
    name: 'The Pyatkov Index',
    url: absUrl(base),
    sameAs: ['https://github.com/JackUait/pyatkov-index'],
  },
  {
    '@type': 'WebPage',
    '@id': `${canonical}#webpage`,
    url: canonical,
    name: title,
    description,
    isPartOf: { '@id': ID.website },
    inLanguage: 'en',
    ...(breadcrumb.length > 0 ? { breadcrumb: { '@id': `${canonical}#breadcrumb` } } : {}),
    ...(mainEntityId ? { mainEntity: { '@id': mainEntityId } } : {}),
    ...(basedOnId ? { isBasedOn: { '@id': basedOnId } } : {}),
  },
  ...(breadcrumb.length > 0
    ? [{
        '@type': 'BreadcrumbList',
        '@id': `${canonical}#breadcrumb`,
        itemListElement: breadcrumb.map((crumb, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: crumb.name,
          ...(crumb.href && i < breadcrumb.length - 1 ? { item: absUrl(crumb.href) } : {}),
        })),
      }]
    : []),
  ...(jsonld === undefined ? [] : Array.isArray(jsonld) ? jsonld : [jsonld]),
];

const here = normalizePath(Astro.url.pathname);
const nav = [
  { href: base, label: 'Rankings' },
  { href: `${base}openness/`, label: 'Openness' },
  { href: `${base}destinations/`, label: 'Destinations' },
  { href: `${base}methodology/`, label: 'Methodology' },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Ahead of the stylesheet on purpose: a preload discovered after it would queue
        behind a render-blocking request that is itself what reveals the font URLs. */}
    <link rel="preload" as="font" type="font/woff2" crossorigin href={interLatin} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={serifLatin} />
    <link rel="preload" as="font" type="font/woff2" crossorigin href={serifLatinItalic} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Only on a real route. GitHub Pages serves 404.html at whatever path was missed,
        so its canonical could never be right — and pointed at /404/ it named a URL that
        itself 404s. */}
    {noindex ? null : <link rel="canonical" href={canonical} />}
    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Pyatkov Index" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#f6f5f4" />
    <ClientRouter />
    {/* The version query pushes browsers past their sticky favicon caches;
        bump it whenever the icon artwork changes (v4: the marigold/midnight
        half split). Safari tends to ignore SVG icons, so the ico is linked
        explicitly, first. */}
    <link rel="icon" href={`${base}favicon.ico?v=4`} sizes="32x32" />
    <link rel="icon" href={`${base}favicon.svg?v=4`} type="image/svg+xml" />
    {/* First paint must already know whether the bar sits on an unscrolled
        page: the elevation module is deferred, and Chrome can paint mid-parse,
        so a same-element or after-the-header script is still too late. Set in
        the head, on <html>, before the body exists. Threshold mirrors
        TOP_THRESHOLD in nav-elevation.ts. Without JS this never runs and the
        safe elevated default stands. */}
    <script is:inline>
      if (window.scrollY <= 8) document.documentElement.toggleAttribute('data-top', true);
    </script>
    {/* is:inline keeps Astro's parser off the payload; set:html with a single
        JSON.stringify escapes it exactly once. */}
    {graph.length > 0 && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': graph })} />
    )}
  </head>
  <body>
    <header transition:persist="header">
      <div class="nav-inner">
        <a href={base} class="brand" aria-label="Pyatkov Index home">
          {/* The weight ribbon in miniature: one decaying spectrum, heaviest
              first. The head steps down through the yellows (saffron, then
              marigold thinning out), the tail fades on in ink washes, and the
              warm-to-neutral boundary still lands at exactly 50%. Slats are
              solid stepped fills throughout — no drawn seams. */}
          <svg class="brand-mark" width="32" height="14" viewBox="0 0 32 14" aria-hidden="true">
            <defs><clipPath id="brand-clip"><rect width="32" height="14" rx="2.5" /></clipPath></defs>
            <g clip-path="url(#brand-clip)">
              <rect width="6" height="14" fill="var(--color-saffron)" />
              <rect x="6" width="4.4" height="14" fill="var(--color-marigold)" />
              <rect x="10.4" width="3.2" height="14" fill="rgba(255, 177, 16, 0.66)" />
              <rect x="13.6" width="2.4" height="14" fill="rgba(255, 177, 16, 0.38)" />
              <rect x="16" width="5.2" height="14" fill="rgba(0, 0, 0, 0.2)" />
              <rect x="21.2" width="4.4" height="14" fill="rgba(0, 0, 0, 0.15)" />
              <rect x="25.6" width="3.6" height="14" fill="rgba(0, 0, 0, 0.11)" />
              <rect x="29.2" width="2.8" height="14" fill="rgba(0, 0, 0, 0.08)" />
            </g>
          </svg>
          <span>Pyatkov Index</span>
        </a>
        <nav>
          {nav.map((item) => (
            <a href={item.href} aria-current={here === normalizePath(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main class={wide ? 'wide' : undefined}><slot /></main>
    {/* The country drawer: passport/destination links open here instead of
        navigating. Sits outside <main> so it survives the inert treatment the
        open drawer applies to the page behind it; country-drawer.ts owns all
        behavior, and without JS the links keep working as plain navigation. */}
    <div class="drawer-root" id="country-drawer" hidden>
      <div class="drawer-scrim"></div>
      <aside class="drawer-panel" role="dialog" aria-modal="true" aria-label="Country details">
        <div class="drawer-bar">
          <button class="drawer-back" id="drawer-back" type="button" hidden>
            <svg viewBox="0 0 16 16" width="13" height="13" aria-hidden="true"><path d="M10.5 2.5 5 8l5.5 5.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
            Back
          </button>
          <span class="drawer-chip" id="drawer-kind"></span>
          <a class="drawer-full" id="drawer-full" href={base} aria-label="Open full page" data-drawer-bypass>
            <span>Open full page</span>
            <svg viewBox="0 0 16 16" width="11" height="11" aria-hidden="true"><path d="M5 3h8v8M13 3 3.5 12.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
          </a>
          <button class="drawer-close" id="drawer-close" type="button" aria-label="Close">
            <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true"><path d="m3.5 3.5 9 9m0-9-9 9" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" /></svg>
          </button>
        </div>
        <div class="drawer-content" id="drawer-content" tabindex="-1"></div>
      </aside>
    </div>
    <footer transition:persist="footer">
      <div class="footer-inner">
        <ul class="footer-links">
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
        {/* Visible counterpart to the Organization node — a structured-data claim with
            nothing on the page behind it is a guidelines violation. */}
        <p><a href="https://github.com/JackUait/pyatkov-index">The Pyatkov Index</a></p>
        <p>{tagline}</p>
        <p>Data: imorte/passport-index-data, the World Bank API, and the UNDP Human Development Report. The index is fully reproducible from the repository.</p>
      </div>
    </footer>
    <script>
      import { initNavElevation } from '../lib/nav-elevation.ts';
      import { initNavCurrent } from '../lib/nav-current.ts';
      import { initCountryDrawer } from '../lib/country-drawer.ts';
      initNavElevation();
      initNavCurrent();
      initCountryDrawer();
    </script>
  </body>
</html>
