---
import '@fontsource-variable/inter';
import '@fontsource/source-serif-pro/400.css';
import '../styles/global.css';
interface Props { title: string; description: string; wide?: boolean }
const { title, description, wide = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const norm = (p: string) => p.replace(/\/+$/, '') || '/';
const here = norm(Astro.url.pathname);
const nav = [
  { href: base, label: 'Rankings' },
  { href: `${base}openness/`, label: 'Openness' },
  { href: `${base}destinations/`, label: 'Destinations' },
  { href: `${base}methodology/`, label: 'Methodology' },
];
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f6f5f4" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header>
      <div class="nav-inner">
        <a href={base} class="brand" aria-label="Pyatkov Index home">
          <svg width="17" height="17" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
            <circle cx="10" cy="10" r="8.2" />
            <ellipse cx="10" cy="10" rx="3.6" ry="8.2" />
            <line x1="1.8" y1="10" x2="18.2" y2="10" />
          </svg>
          <span>Pyatkov Index</span>
        </a>
        <nav>
          {nav.map((item) => (
            <a href={item.href} aria-current={here === norm(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>
    <main class={wide ? 'wide' : undefined}><slot /></main>
    <footer>
      <div class="footer-inner">
        <ul class="footer-links">
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
        <p>Not all destinations are equal. The Pyatkov Index weights every destination by how much access to it is actually worth.</p>
        <p>Data: imorte/passport-index-data, the World Bank API, and the UNDP Human Development Report. The index is fully reproducible from the repository.</p>
      </div>
    </footer>
  </body>
</html>
